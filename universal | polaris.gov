-- ============================================================
-- // CONNECTION MANAGER
-- ============================================================

local Connections = {}
local function Conn(name, c)
    if Connections[name] then Connections[name]:Disconnect() end
    Connections[name] = c
end
local function Drop(name)
    if Connections[name] then
        Connections[name]:Disconnect()
        Connections[name] = nil
    end
end

