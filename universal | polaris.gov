local GuiVisible=true
UserInputService.InputBegan:Connect(function(inp,gpe)
    if gpe then return end
    if inp.KeyCode==Enum.KeyCode.RightAlt then GuiVisible=not GuiVisible; MainFrame.Visible=GuiVisible end
end)

do
    local dragging,dragStart,startPos
    MainFrame.InputBegan:Connect(function(inp)
        if inp.UserInputType~=Enum.UserInputType.MouseButton1 then return end
        if inp.Position.Y-MainFrame.AbsolutePosition.Y<=44 then
            dragging=true; dragStart=inp.Position; startPos=MainFrame.Position end
    end)
    UserInputService.InputChanged:Connect(function(inp)
        if not dragging or inp.UserInputType~=Enum.UserInputType.MouseMovement then return end
        local d=inp.Position-dragStart
        MainFrame.Position=UDim2.new(startPos.X.Scale,startPos.X.Offset+d.X,startPos.Y.Scale,startPos.Y.Offset+d.Y)
    end)
    UserInputService.InputEnded:Connect(function(inp)
        if inp.UserInputType==Enum.UserInputType.MouseButton1 then dragging=false end
    end)
end

-- ============================================================
-- // TAB SYSTEM
-- ============================================================

local Tabs={}; local ActiveTab=nil; local TabOrder=0

local function SwitchTab(name)
    if ActiveTab==name then return end; ActiveTab=name; ActiveTabLabel.Text=name
    for n,t in pairs(Tabs) do
        local on=(n==name)
        Tween(t.Btn,T_FAST,{BackgroundColor3=on and C.AccentDim or Color3.fromRGB(0,0,0),BackgroundTransparency=on and 0 or 1})
        Tween(t.BtnLabel,T_FAST,{TextColor3=on and C.AccentGlow or C.TextDim})
        t.Scroll.Visible=on
    end
end

local OpenPopups={}
local function CloseAllPopups()
    for _,ref in ipairs(OpenPopups) do
        if ref.frame and ref.frame.Parent then ref.frame.Visible=false; ref.open=false end
    end
end
local function PointInAnyPopup(px,py)
    for _,ref in ipairs(OpenPopups) do
        if ref.open and ref.frame and ref.frame.Visible then
            local ap=ref.frame.AbsolutePosition; local as=ref.frame.AbsoluteSize
            if px>=ap.X and px<=ap.X+as.X and py>=ap.Y and py<=ap.Y+as.Y then return true end
        end
    end; return false
end

local function CreateTab(name)
    TabOrder=TabOrder+1
    local btn=New("TextButton",{Size=UDim2.new(1,0,0,30),BackgroundColor3=Color3.fromRGB(0,0,0),
        BackgroundTransparency=1,Text="",BorderSizePixel=0,LayoutOrder=TabOrder,ZIndex=4,Parent=TabButtonList},
        {New("UICorner",{CornerRadius=UDim.new(0,6)})})
    local btnLabel=New("TextLabel",{Size=UDim2.new(1,-10,1,0),Position=UDim2.new(0,10,0,0),
        BackgroundTransparency=1,Text=name,Font=Enum.Font.Gotham,TextSize=12,TextColor3=C.TextDim,
        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=5,Parent=btn})
    local scroll=New("ScrollingFrame",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,
        ScrollBarThickness=3,ScrollBarImageColor3=C.AccentDim,CanvasSize=UDim2.fromScale(0,0),
        AutomaticCanvasSize=Enum.AutomaticSize.Y,Visible=false,ZIndex=2,Parent=ContentPanel},{
        New("UIListLayout",{Padding=UDim.new(0,6),FillDirection=Enum.FillDirection.Vertical,SortOrder=Enum.SortOrder.LayoutOrder}),
        New("UIPadding",{PaddingLeft=UDim.new(0,14),PaddingRight=UDim.new(0,14),PaddingTop=UDim.new(0,12),PaddingBottom=UDim.new(0,12)})})
    btn.MouseButton1Click:Connect(function() SwitchTab(name) end)
    btn.MouseEnter:Connect(function()
        if ActiveTab~=name then Tween(btn,T_FAST,{BackgroundTransparency=0.6,BackgroundColor3=C.Element})
            Tween(btnLabel,T_FAST,{TextColor3=C.Text}) end end)
    btn.MouseLeave:Connect(function()
        if ActiveTab~=name then Tween(btn,T_FAST,{BackgroundTransparency=1})
            Tween(btnLabel,T_FAST,{TextColor3=C.TextDim}) end end)
    local tabObj={Btn=btn,BtnLabel=btnLabel,Scroll=scroll,Order=0}
    Tabs[name]=tabObj
    local Tab={}
    local function NO() tabObj.Order=tabObj.Order+1; return tabObj.Order end

    function Tab:CreateSection(title)
        local f=New("Frame",{Size=UDim2.new(1,0,0,26),BackgroundTransparency=1,LayoutOrder=NO(),Parent=scroll})
        New("TextLabel",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text=string.upper(title),
            Font=Enum.Font.GothamBold,TextSize=10,TextColor3=C.Accent,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=f})
        New("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),BackgroundColor3=C.Border,BorderSizePixel=0,ZIndex=3,Parent=f})
    end

    function Tab:CreateLabel(text)
        New("TextLabel",{Size=UDim2.new(1,0,0,22),BackgroundTransparency=1,Text=text,Font=Enum.Font.Gotham,
            TextSize=11,TextColor3=C.TextMuted,TextXAlignment=Enum.TextXAlignment.Left,
            TextWrapped=true,LayoutOrder=NO(),ZIndex=3,Parent=scroll})
    end

    function Tab:CreateToggle(config)
        local val=config.CurrentValue or false
        local row=New("Frame",{Size=UDim2.new(1,0,0,36),BackgroundColor3=C.Element,BorderSizePixel=0,LayoutOrder=NO(),Parent=scroll},
            {New("UICorner",{CornerRadius=UDim.new(0,7)})})
        New("TextLabel",{Size=UDim2.new(1,-58,1,0),Position=UDim2.new(0,12,0,0),BackgroundTransparency=1,
            Text=config.Name,Font=Enum.Font.Gotham,TextSize=12,TextColor3=C.Text,
            TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=row})
        local pill=New("Frame",{Size=UDim2.fromOffset(36,20),Position=UDim2.new(1,-46,0.5,-10),
            BackgroundColor3=val and C.On or C.Off,BorderSizePixel=0,ZIndex=3,Parent=row},
            {New("UICorner",{CornerRadius=UDim.new(1,0)})})
        local knob=New("Frame",{Size=UDim2.fromOffset(14,14),
            Position=val and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7),
            BackgroundColor3=C.White,BorderSizePixel=0,ZIndex=4,Parent=pill},
            {New("UICorner",{CornerRadius=UDim.new(1,0)})})
        local function Set(v)
            val=v; Tween(pill,T_FAST,{BackgroundColor3=v and C.On or C.Off})
            Tween(knob,T_FAST,{Position=v and UDim2.new(1,-17,0.5,-7) or UDim2.new(0,3,0.5,-7)})
            if config.Callback then config.Callback(v) end
        end
        local hb=New("TextButton",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="",ZIndex=5,Parent=row})
        hb.MouseButton1Click:Connect(function() Set(not val) end)
        hb.MouseEnter:Connect(function() Tween(row,T_FAST,{BackgroundColor3=C.ElemHov}) end)
        hb.MouseLeave:Connect(function() Tween(row,T_FAST,{BackgroundColor3=C.Element}) end)
        if config.StateGet then RegisterSetter(config.StateGet,function(v) Set(v) end) end
        return {Set=Set}
    end

    function Tab:CreateSlider(config)
        local val=config.CurrentValue or config.Range[1]
        local minV=config.Range[1]; local maxV=config.Range[2]
        local inc=config.Increment or 1; local suf=config.Suffix or ""
        local con=New("Frame",{Size=UDim2.new(1,0,0,52),BackgroundColor3=C.Element,BorderSizePixel=0,LayoutOrder=NO(),Parent=scroll},
            {New("UICorner",{CornerRadius=UDim.new(0,7)})})
        New("TextLabel",{Size=UDim2.new(0.65,-12,0,26),Position=UDim2.new(0,12,0,0),BackgroundTransparency=1,
            Text=config.Name,Font=Enum.Font.Gotham,TextSize=12,TextColor3=C.Text,
            TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=con})
        local vl=New("TextLabel",{Size=UDim2.new(0.35,-12,0,26),Position=UDim2.new(0.65,0,0,0),
            BackgroundTransparency=1,Text=tostring(val)..suf,Font=Enum.Font.GothamBold,
            TextSize=11,TextColor3=C.Accent,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=3,Parent=con})
        local trk=New("Frame",{Size=UDim2.new(1,-24,0,6),Position=UDim2.new(0,12,0,36),
            BackgroundColor3=C.SliderBG,BorderSizePixel=0,ZIndex=3,Parent=con},
            {New("UICorner",{CornerRadius=UDim.new(1,0)})})
        local ip=(val-minV)/(maxV-minV)
        local fil=New("Frame",{Size=UDim2.new(ip,0,1,0),BackgroundColor3=C.SliderFill,BorderSizePixel=0,ZIndex=4,Parent=trk},
            {New("UICorner",{CornerRadius=UDim.new(1,0)})})
        local th=New("Frame",{Size=UDim2.fromOffset(12,12),Position=UDim2.new(ip,-6,0.5,-6),
            BackgroundColor3=C.White,BorderSizePixel=0,ZIndex=5,Parent=trk},
            {New("UICorner",{CornerRadius=UDim.new(1,0)})})
        local function SV(pct)
            pct=math.clamp(pct,0,1)
            local sv=math.clamp(math.round((minV+pct*(maxV-minV))/inc)*inc,minV,maxV)
            val=sv; local dp=(sv-minV)/(maxV-minV)
            fil.Size=UDim2.new(dp,0,1,0); th.Position=UDim2.new(dp,-6,0.5,-6)
            vl.Text=tostring(sv)..suf; if config.Callback then config.Callback(sv) end
        end
        local ha=New("TextButton",{Size=UDim2.new(1,0,0,22),Position=UDim2.new(0,0,0.5,-11),
            BackgroundTransparency=1,Text="",ZIndex=6,Parent=trk})
        ha.MouseButton1Down:Connect(function()
            _activeSlide={sv=SV,trk=trk}
            SV((UserInputService:GetMouseLocation().X-trk.AbsolutePosition.X)/trk.AbsoluteSize.X)
        end)
        con.MouseEnter:Connect(function() Tween(con,T_FAST,{BackgroundColor3=C.ElemHov}) end)
        con.MouseLeave:Connect(function() Tween(con,T_FAST,{BackgroundColor3=C.Element}) end)
        if config.StateGet then
            RegisterSetter(config.StateGet,function(v)
                SV((v-minV)/math.max(maxV-minV,0.001)) end)
        end
        return {Set=function(v) SV((v-minV)/math.max(maxV-minV,0.001)) end}
    end

    -- FIX: Added ColorStateGet so the color swatch updates when SyncGUI is called
    -- after a config load. Without this the swatch always shows the initial color
    -- regardless of what the config contains.
    function Tab:CreateColorPicker(config)
        local curCol=config.Color or Color3.fromRGB(255,255,255); local rbOn=false; local noRB=config.NoRainbow==true
        local con=New("Frame",{Size=UDim2.new(1,0,0,36),BackgroundColor3=C.Element,BorderSizePixel=0,LayoutOrder=NO(),Parent=scroll},
            {New("UICorner",{CornerRadius=UDim.new(0,7)})})
        New("TextLabel",{Size=UDim2.new(1,-90,1,0),Position=UDim2.new(0,12,0,0),BackgroundTransparency=1,
            Text=config.Name,Font=Enum.Font.Gotham,TextSize=12,TextColor3=C.Text,
            TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=con})
        local rbPill=New("Frame",{Size=UDim2.fromOffset(28,16),Position=UDim2.new(1,-66,0.5,-8),
            BackgroundColor3=C.Off,BorderSizePixel=0,ZIndex=4,Visible=not noRB,Parent=con},
            {New("UICorner",{CornerRadius=UDim.new(1,0)})})
        New("TextLabel",{Size=UDim2.new(1,0,0,10),Position=UDim2.new(0,0,-0.5,0),BackgroundTransparency=1,
            Text="RB",Font=Enum.Font.GothamBold,TextSize=7,TextColor3=C.TextMuted,
            TextXAlignment=Enum.TextXAlignment.Center,ZIndex=5,Parent=rbPill})
        local rbKnob=New("Frame",{Size=UDim2.fromOffset(10,10),Position=UDim2.new(0,3,0.5,-5),
            BackgroundColor3=C.White,BorderSizePixel=0,ZIndex=5,Parent=rbPill},
            {New("UICorner",{CornerRadius=UDim.new(1,0)})})
        local function SetRB(v)
            rbOn=v; Tween(rbPill,T_FAST,{BackgroundColor3=v and C.On or C.Off})
            Tween(rbKnob,T_FAST,{Position=v and UDim2.new(1,-13,0.5,-5) or UDim2.new(0,3,0.5,-5)})
            if config.RainbowCallback then config.RainbowCallback(v) end
        end
        if not noRB then
            local rbHB=New("TextButton",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="",ZIndex=6,Parent=rbPill})
            rbHB.MouseButton1Click:Connect(function() SetRB(not rbOn) end)
        end
        local sw=New("Frame",{Size=UDim2.fromOffset(22,22),Position=UDim2.new(1,-36,0.5,-11),
            BackgroundColor3=curCol,BorderSizePixel=0,ZIndex=4,Parent=con},
            {New("UICorner",{CornerRadius=UDim.new(0,4)}),New("UIStroke",{Color=C.Border,Thickness=1})})
        local presets={Color3.fromRGB(255,0,0),Color3.fromRGB(255,165,0),Color3.fromRGB(255,255,0),
            Color3.fromRGB(0,255,80),Color3.fromRGB(0,200,255),Color3.fromRGB(99,130,255),
            Color3.fromRGB(180,0,255),Color3.fromRGB(255,100,180),Color3.fromRGB(255,255,255),Color3.fromRGB(150,150,150)}
        local popup=New("Frame",{Size=UDim2.fromOffset(164,68),BackgroundColor3=C.Panel,BorderSizePixel=0,
            Visible=false,ZIndex=200,Parent=ScreenGui},{
            New("UICorner",{CornerRadius=UDim.new(0,7)}),New("UIStroke",{Color=C.Border,Thickness=1}),
            New("UIGridLayout",{CellSize=UDim2.fromOffset(20,20),CellPadding=UDim2.fromOffset(4,4)}),
            New("UIPadding",{PaddingLeft=UDim.new(0,8),PaddingRight=UDim.new(0,8),PaddingTop=UDim.new(0,8)})})
        local ref={frame=popup,open=false}; table.insert(OpenPopups,ref)
        for _,col in ipairs(presets) do
            local cell=New("TextButton",{Size=UDim2.fromOffset(20,20),BackgroundColor3=col,Text="",
                BorderSizePixel=0,ZIndex=201,Parent=popup},{New("UICorner",{CornerRadius=UDim.new(0,4)})})
            cell.MouseButton1Click:Connect(function()
                curCol=col; sw.BackgroundColor3=col; popup.Visible=false; ref.open=false
                if config.Callback then config.Callback(col) end
            end)
        end
        local sb=New("TextButton",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="",ZIndex=5,Parent=sw})
        sb.MouseButton1Click:Connect(function()
            CloseAllPopups()
            if not ref.open then
                local ap=sw.AbsolutePosition; local as=sw.AbsoluteSize
                local py=ap.Y-68-4; if py<0 then py=ap.Y+as.Y+4 end
                popup.Position=UDim2.fromOffset(ap.X-140,py); popup.Visible=true; ref.open=true
            end
        end)
        con.MouseEnter:Connect(function() Tween(con,T_FAST,{BackgroundColor3=C.ElemHov}) end)
        con.MouseLeave:Connect(function() Tween(con,T_FAST,{BackgroundColor3=C.Element}) end)
        if config.RainbowStateGet then RegisterSetter(config.RainbowStateGet,function(v) SetRB(v) end) end
        -- FIX: Register swatch color sync via ColorStateGet
        if config.ColorStateGet then
            RegisterSetter(config.ColorStateGet, function(v)
                curCol = v
                sw.BackgroundColor3 = v
            end)
        end
    end

    function Tab:CreateButton(config)
        local b=New("TextButton",{Size=UDim2.new(1,0,0,34),BackgroundColor3=C.Element,BorderSizePixel=0,
            LayoutOrder=NO(),Text="",Parent=scroll},{New("UICorner",{CornerRadius=UDim.new(0,7)})})
        New("TextLabel",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text=config.Name,
            Font=Enum.Font.GothamBold,TextSize=12,TextColor3=C.Accent,ZIndex=3,Parent=b})
        b.MouseButton1Click:Connect(function() if config.Callback then config.Callback() end end)
        b.MouseEnter:Connect(function() Tween(b,T_FAST,{BackgroundColor3=C.ElemHov}) end)
        b.MouseLeave:Connect(function() Tween(b,T_FAST,{BackgroundColor3=C.Element}) end)
    end

    function Tab:CreateDisplay(config)
        local row=New("Frame",{Size=UDim2.new(1,0,0,36),BackgroundColor3=C.Element,BorderSizePixel=0,LayoutOrder=NO(),Parent=scroll},
            {New("UICorner",{CornerRadius=UDim.new(0,7)})})
        New("TextLabel",{Size=UDim2.new(0.4,0,1,0),Position=UDim2.new(0,12,0,0),BackgroundTransparency=1,
            Text=config.Name,Font=Enum.Font.Gotham,TextSize=12,TextColor3=C.TextDim,
            TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=row})
        local vl=New("TextLabel",{Size=UDim2.new(0.6,-12,1,0),Position=UDim2.new(0.4,0,0,0),
            BackgroundTransparency=1,Text=config.DefaultText or "",Font=Enum.Font.GothamBold,
            TextSize=11,TextColor3=C.Accent,TextXAlignment=Enum.TextXAlignment.Right,ZIndex=3,Parent=row})
        return function(t) vl.Text=t end
    end

    function Tab:CreateTextInput(config)
        local con=New("Frame",{Size=UDim2.new(1,0,0,56),BackgroundColor3=C.Element,BorderSizePixel=0,LayoutOrder=NO(),Parent=scroll},
            {New("UICorner",{CornerRadius=UDim.new(0,7)})})
        New("TextLabel",{Size=UDim2.new(1,-24,0,22),Position=UDim2.new(0,12,0,0),BackgroundTransparency=1,
            Text=config.Name,Font=Enum.Font.Gotham,TextSize=12,TextColor3=C.Text,
            TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=con})
        local tb=New("TextBox",{Size=UDim2.new(1,-24,0,26),Position=UDim2.new(0,12,0,24),
            BackgroundColor3=C.SliderBG,BorderSizePixel=0,Text=config.DefaultText or "",
            PlaceholderText=config.Placeholder or "...",Font=Enum.Font.Gotham,TextSize=12,
            TextColor3=C.Text,PlaceholderColor3=C.TextMuted,ClearTextOnFocus=false,ZIndex=4,Parent=con},{
            New("UICorner",{CornerRadius=UDim.new(0,5)}),
            New("UIPadding",{PaddingLeft=UDim.new(0,6),PaddingRight=UDim.new(0,6)})})
        tb.FocusLost:Connect(function() if config.Callback then config.Callback(tb.Text) end end)
        con.MouseEnter:Connect(function() Tween(con,T_FAST,{BackgroundColor3=C.ElemHov}) end)
        con.MouseLeave:Connect(function() Tween(con,T_FAST,{BackgroundColor3=C.Element}) end)
    end

    -- FIX: Added StateGet support so SyncGUI can update the displayed key label
    -- after a config is loaded. Previously the keybind label was write-once.
    function Tab:CreateKeybind(config)
        local curKey=config.DefaultKey or "MouseButton2"; local listening=false
        local row=New("Frame",{Size=UDim2.new(1,0,0,36),BackgroundColor3=C.Element,BorderSizePixel=0,LayoutOrder=NO(),Parent=scroll},
            {New("UICorner",{CornerRadius=UDim.new(0,7)})})
        New("TextLabel",{Size=UDim2.new(0.6,0,1,0),Position=UDim2.new(0,12,0,0),BackgroundTransparency=1,
            Text=config.Name,Font=Enum.Font.Gotham,TextSize=12,TextColor3=C.Text,
            TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=row})
        local kb=New("TextButton",{Size=UDim2.new(0.38,0,0,22),Position=UDim2.new(0.62,0,0.5,-11),
            BackgroundColor3=C.SliderBG,BorderSizePixel=0,Text=curKey,Font=Enum.Font.GothamBold,
            TextSize=10,TextColor3=C.Accent,ZIndex=4,Parent=row},{New("UICorner",{CornerRadius=UDim.new(0,5)})})
        -- Internal setter used both by user interaction and by SyncGUI
        local function SetKey(kn)
            curKey = kn; kb.Text = kn; kb.TextColor3 = C.Accent
            if config.Callback then config.Callback(kn) end
        end
        kb.MouseButton1Click:Connect(function()
            if listening then return end; listening=true; kb.Text="..."; kb.TextColor3=C.TextDim
            local conn; conn=UserInputService.InputBegan:Connect(function(inp,gpe)
                if gpe then return end; listening=false; conn:Disconnect()
                local kn
                if     inp.UserInputType==Enum.UserInputType.MouseButton2 then kn="MouseButton2"
                elseif inp.UserInputType==Enum.UserInputType.MouseButton1 then kn="MouseButton1"
                elseif inp.UserInputType==Enum.UserInputType.MouseButton3 then kn="MouseButton3"
                elseif inp.UserInputType==Enum.UserInputType.Keyboard      then kn=inp.KeyCode.Name
                else kn=curKey end
                SetKey(kn)
            end)
        end)
        row.MouseEnter:Connect(function() Tween(row,T_FAST,{BackgroundColor3=C.ElemHov}) end)
        row.MouseLeave:Connect(function() Tween(row,T_FAST,{BackgroundColor3=C.Element}) end)
        -- FIX: register with GUISetters if StateGet is provided
        if config.StateGet then
            RegisterSetter(config.StateGet, function(v)
                curKey = v; kb.Text = v; kb.TextColor3 = C.Accent
            end)
        end
        return { SetKey = SetKey }
    end

    return Tab
end

-- ============================================================
-- // NOTIFICATION
-- ============================================================

PolarisNotify=function(title,content,duration)
    local notif=New("Frame",{Size=UDim2.fromOffset(240,56),BackgroundColor3=C.Panel,BorderSizePixel=0,
        ZIndex=100,Parent=ScreenGui},{New("UICorner",{CornerRadius=UDim.new(0,8)}),New("UIStroke",{Color=C.Accent,Thickness=1})})
    New("Frame",{Size=UDim2.fromOffset(3,36),Position=UDim2.new(0,0,0.5,-18),BackgroundColor3=C.Accent,
        BorderSizePixel=0,ZIndex=101,Parent=notif},{New("UICorner",{CornerRadius=UDim.new(1,0)})})
    New("TextLabel",{Size=UDim2.new(1,-18,0,18),Position=UDim2.new(0,14,0,8),BackgroundTransparency=1,
        Text=title,Font=Enum.Font.GothamBold,TextSize=12,TextColor3=C.Text,
        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=101,Parent=notif})
    New("TextLabel",{Size=UDim2.new(1,-18,0,14),Position=UDim2.new(0,14,0,28),BackgroundTransparency=1,
        Text=content,Font=Enum.Font.Gotham,TextSize=10,TextColor3=C.TextDim,
        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=101,Parent=notif})
    notif.Position=UDim2.new(1,16,1,-72); Tween(notif,T_MED,{Position=UDim2.new(1,-256,1,-72)})
    task.delay(duration or 4,function()
        Tween(notif,T_MED,{Position=UDim2.new(1,16,1,-72)}); task.wait(0.3)
        if notif and notif.Parent then notif:Destroy() end
    end)
end

-- ============================================================
-- // BUILD TABS
-- ============================================================

local AimbotTab=CreateTab("Aimbot"); local ESPTab=CreateTab("ESP"); local MovementTab=CreateTab("Movement")
local MusicTab=CreateTab("Music");   local VisualTab=CreateTab("Visuals"); local HitboxTab=CreateTab("Hitbox")
local MiscTab=CreateTab("Misc");     local ConfigsTab=CreateTab("Configs")

-- ── AIMBOT ────────────────────────────────────────────────────

AimbotTab:CreateSection("Aimbot")
AimbotTab:CreateToggle({Name="Enable Aimbot",CurrentValue=false,StateGet=function() return State.Aimbot.Enabled end,
    Callback=function(v) State.Aimbot.Enabled=v; SetupAimbot() end})
AimbotTab:CreateToggle({Name="Stay Locked (hold key = same target)",CurrentValue=false,
    StateGet=function() return State.Aimbot.KeepLocked end,Callback=function(v) State.Aimbot.KeepLocked=v end})
AimbotTab:CreateToggle({Name="Wall Check (Raycast)",CurrentValue=false,
    StateGet=function() return State.Aimbot.WallCheck end,Callback=function(v) State.Aimbot.WallCheck=v end})
AimbotTab:CreateToggle({Name="Prediction",CurrentValue=false,
    StateGet=function() return State.Aimbot.Prediction end,Callback=function(v) State.Aimbot.Prediction=v end})
AimbotTab:CreateSlider({Name="Prediction Strength",Range={1,200},Increment=1,Suffix="ms",CurrentValue=65,
    StateGet=function() return math.floor(State.Aimbot.PredictionStrength*1000+0.5) end,
    Callback=function(v) State.Aimbot.PredictionStrength=v/1000 end})
AimbotTab:CreateSlider({Name="Aim Speed",Range={1,100},Increment=1,Suffix="%",CurrentValue=50,
    StateGet=function() return math.floor(State.Aimbot.Smoothness*100+0.5) end,
    Callback=function(v) State.Aimbot.Smoothness=v/100 end})
AimbotTab:CreateSlider({Name="FOV Radius",Range={10,500},Increment=5,Suffix="px",CurrentValue=150,
    StateGet=function() return State.Aimbot.FOV end,Callback=function(v) State.Aimbot.FOV=v end})
