    nameBox:GetPropertyChangedSignal("Text"):Connect(function() cfgNameValue=nameBox.Text end)
    nic.MouseEnter:Connect(function() Tween(nic,T_FAST,{BackgroundColor3=C.ElemHov}) end)
    nic.MouseLeave:Connect(function() Tween(nic,T_FAST,{BackgroundColor3=C.Element}) end)
    local s2=New("Frame",{Size=UDim2.new(1,0,0,26),BackgroundTransparency=1,LayoutOrder=NO_C(),Parent=cfgScroll})
    New("TextLabel",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="SAVED PROFILES",Font=Enum.Font.GothamBold,
        TextSize=10,TextColor3=C.Accent,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=s2})
    New("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),BackgroundColor3=C.Border,BorderSizePixel=0,ZIndex=3,Parent=s2})
    local cfgList=New("Frame",{Size=UDim2.new(1,0,0,0),AutomaticSize=Enum.AutomaticSize.Y,
        BackgroundTransparency=1,LayoutOrder=NO_C(),Parent=cfgScroll},
        {New("UIListLayout",{Padding=UDim.new(0,4),SortOrder=Enum.SortOrder.LayoutOrder,FillDirection=Enum.FillDirection.Vertical})})
    local s3=New("Frame",{Size=UDim2.new(1,0,0,26),BackgroundTransparency=1,LayoutOrder=NO_C(),Parent=cfgScroll})
    New("TextLabel",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="STATUS",Font=Enum.Font.GothamBold,
        TextSize=10,TextColor3=C.Accent,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=s3})
    New("Frame",{Size=UDim2.new(1,0,0,1),Position=UDim2.new(0,0,1,-1),BackgroundColor3=C.Border,BorderSizePixel=0,ZIndex=3,Parent=s3})
    local statusRow=New("Frame",{Size=UDim2.new(1,0,0,36),BackgroundColor3=C.Element,BorderSizePixel=0,LayoutOrder=NO_C(),Parent=cfgScroll},
        {New("UICorner",{CornerRadius=UDim.new(0,7)})})
    New("TextLabel",{Size=UDim2.new(0.4,0,1,0),Position=UDim2.new(0,12,0,0),BackgroundTransparency=1,
        Text="Active Config",Font=Enum.Font.Gotham,TextSize=12,TextColor3=C.TextDim,
        TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=statusRow})
    local statusLabel=New("TextLabel",{Size=UDim2.new(0.6,-12,1,0),Position=UDim2.new(0.4,0,0,0),
        BackgroundTransparency=1,Text="none",Font=Enum.Font.GothamBold,TextSize=11,TextColor3=C.Accent,
        TextXAlignment=Enum.TextXAlignment.Right,ZIndex=3,Parent=statusRow})
    _cfgStatusLabel=statusLabel
    New("TextLabel",{Size=UDim2.new(1,0,0,32),BackgroundTransparency=1,
        Text="Note: toggle features off/on after loading to refresh GUI visuals.",
        Font=Enum.Font.Gotham,TextSize=10,TextColor3=C.TextMuted,TextXAlignment=Enum.TextXAlignment.Left,
        TextWrapped=true,LayoutOrder=NO_C(),ZIndex=3,Parent=cfgScroll})
    local function RefreshCFGList()
        for _,child in ipairs(cfgList:GetChildren()) do if not child:IsA("UIListLayout") then child:Destroy() end end
        local names=CFGList()
        if #names==0 then
            New("TextLabel",{Size=UDim2.new(1,0,0,28),BackgroundTransparency=1,Text="No saved profiles found.",
                Font=Enum.Font.Gotham,TextSize=11,TextColor3=C.TextMuted,TextXAlignment=Enum.TextXAlignment.Left,
                LayoutOrder=1,ZIndex=3,Parent=cfgList}); return
        end
        for i,name in ipairs(names) do
            local row=New("Frame",{Size=UDim2.new(1,0,0,36),BackgroundColor3=C.Element,BorderSizePixel=0,
                LayoutOrder=i,ZIndex=3,Parent=cfgList},{New("UICorner",{CornerRadius=UDim.new(0,7)})})
            New("TextLabel",{Size=UDim2.new(1,-88,1,0),Position=UDim2.new(0,10,0,0),BackgroundTransparency=1,
                Text=name,Font=Enum.Font.Gotham,TextSize=11,TextColor3=C.Text,
                TextXAlignment=Enum.TextXAlignment.Left,ZIndex=4,Parent=row})
            local loadB=New("TextButton",{Size=UDim2.fromOffset(36,22),Position=UDim2.new(1,-80,0.5,-11),
                BackgroundColor3=C.AccentDim,BorderSizePixel=0,Text="Load",Font=Enum.Font.GothamBold,
                TextSize=9,TextColor3=C.White,ZIndex=4,Parent=row},{New("UICorner",{CornerRadius=UDim.new(0,5)})})
            loadB.MouseButton1Click:Connect(function()
                local ok,msg=CFGLoad(name)
                if ok then statusLabel.Text=name; PolarisNotify("Config","Loaded: "..name,3)
                else PolarisNotify("Config","Load failed: "..(msg or "?"),3) end end)
            loadB.MouseEnter:Connect(function() Tween(loadB,T_FAST,{BackgroundColor3=C.Accent}) end)
            loadB.MouseLeave:Connect(function() Tween(loadB,T_FAST,{BackgroundColor3=C.AccentDim}) end)
            local delB=New("TextButton",{Size=UDim2.fromOffset(36,22),Position=UDim2.new(1,-40,0.5,-11),
                BackgroundColor3=C.Red,BorderSizePixel=0,Text="Del",Font=Enum.Font.GothamBold,
                TextSize=9,TextColor3=C.White,ZIndex=4,Parent=row},{New("UICorner",{CornerRadius=UDim.new(0,5)})})
            delB.MouseButton1Click:Connect(function()
                CFGDelete(name); if statusLabel.Text==name then statusLabel.Text="none" end
                PolarisNotify("Config","Deleted: "..name,2); RefreshCFGList() end)
            delB.MouseEnter:Connect(function() Tween(delB,T_FAST,{BackgroundColor3=Color3.fromRGB(255,80,80)}) end)
            delB.MouseLeave:Connect(function() Tween(delB,T_FAST,{BackgroundColor3=C.Red}) end)
        end
    end
    local saveBtn=New("TextButton",{Size=UDim2.new(1,0,0,34),BackgroundColor3=C.Element,BorderSizePixel=0,LayoutOrder=NO_C(),Text="",Parent=cfgScroll},
        {New("UICorner",{CornerRadius=UDim.new(0,7)})})
    New("TextLabel",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="Save Current Config",
        Font=Enum.Font.GothamBold,TextSize=12,TextColor3=C.Accent,ZIndex=3,Parent=saveBtn})
    saveBtn.MouseButton1Click:Connect(function()
        local name=cfgNameValue:gsub("^%s+",""):gsub("%s+$","")
        if name=="" then PolarisNotify("Config","Enter a profile name first.",2); return end
        local ok,msg=CFGSave(name)
        if ok then statusLabel.Text=name; PolarisNotify("Config","Saved: "..name,3); RefreshCFGList()
        else PolarisNotify("Config","Save failed: "..(msg or "?"),3) end end)
    saveBtn.MouseEnter:Connect(function() Tween(saveBtn,T_FAST,{BackgroundColor3=C.ElemHov}) end)
    saveBtn.MouseLeave:Connect(function() Tween(saveBtn,T_FAST,{BackgroundColor3=C.Element}) end)
    local refreshBtn=New("TextButton",{Size=UDim2.new(1,0,0,34),BackgroundColor3=C.Element,BorderSizePixel=0,LayoutOrder=NO_C(),Text="",Parent=cfgScroll},
        {New("UICorner",{CornerRadius=UDim.new(0,7)})})
    New("TextLabel",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="Refresh Profile List",
        Font=Enum.Font.GothamBold,TextSize=12,TextColor3=C.TextDim,ZIndex=3,Parent=refreshBtn})
    refreshBtn.MouseButton1Click:Connect(function() RefreshCFGList(); PolarisNotify("Config","List refreshed.",1.5) end)
    refreshBtn.MouseEnter:Connect(function() Tween(refreshBtn,T_FAST,{BackgroundColor3=C.ElemHov}) end)
    refreshBtn.MouseLeave:Connect(function() Tween(refreshBtn,T_FAST,{BackgroundColor3=C.Element}) end)
    RefreshCFGList()
end

