HitboxTab:CreateSection("Hitbox Expander")
HitboxTab:CreateLabel("For Hitbox Expander to work, you must use HRP Expander.")
HitboxTab:CreateToggle({Name="Enable Hitbox Expander",CurrentValue=false,
    StateGet=function() return State.Hitbox.Enabled end,
    Callback=function(v) State.Hitbox.Enabled=v; SetupHitbox() end})
HitboxTab:CreateSlider({Name="Expansion Size",Range={0,15},Increment=1,Suffix=" st",CurrentValue=4,
    StateGet=function() return State.Hitbox.Size end,Callback=function(v) State.Hitbox.Size=v end})
HitboxTab:CreateSlider({Name="Part Transparency",Range={0,100},Increment=1,Suffix="%",CurrentValue=100,
    StateGet=function() return math.floor(State.Hitbox.Transparency*100+0.5) end,
    Callback=function(v)
        State.Hitbox.Transparency=v/100
        if State.Hitbox.Enabled then
            for _,entry in pairs(HitboxData) do
                for part in pairs(entry.parts) do
                    pcall(function() if part and part.Parent then part.Transparency=State.Hitbox.Transparency end end)
                end
            end
        end
    end})
HitboxTab:CreateColorPicker({Name="Highlight Color",Color=Color3.fromRGB(255,60,60),NoRainbow=true,
    ColorStateGet=function() return State.Hitbox.Color end,
    Callback=function(v) State.Hitbox.Color=v end})
HitboxTab:CreateToggle({Name="Show Highlight on Players",CurrentValue=false,
    StateGet=function() return State.Hitbox.Highlight end,Callback=function(v) State.Hitbox.Highlight=v end})
HitboxTab:CreateToggle({Name="Team Check (skip teammates)",CurrentValue=true,
    StateGet=function() return State.Hitbox.TeamCheck end,
    Callback=function(v) State.Hitbox.TeamCheck=v; if State.Hitbox.Enabled then ClearAllHitboxes(); SetupHitbox() end end})
HitboxTab:CreateSection("HRP Expander (Multiplier Mode)")
HitboxTab:CreateToggle({Name="Enable HRP Expander",CurrentValue=false,
    StateGet=function() return State.Hitbox.HRPEnabled end,
    Callback=function(v)
        State.Hitbox.HRPEnabled=v
        if State.Hitbox.Enabled then ClearAllHitboxes(); SetupHitbox() end
    end})
HitboxTab:CreateSlider({Name="HRP Multiplier",Range={10,200},Increment=5,Suffix="x/10",CurrentValue=20,
    StateGet=function() return math.floor(State.Hitbox.HRPMultiplier*10+0.5) end,
    Callback=function(v)
        State.Hitbox.HRPMultiplier=v/10
        if State.Hitbox.Enabled and State.Hitbox.HRPEnabled then
            for _,entry in pairs(HitboxData) do
                if entry.hrpPart and entry.hrpOrigSize and entry.hrpPart.Parent then
                    local baseSize=math.max(entry.hrpOrigSize.X,entry.hrpOrigSize.Y,entry.hrpOrigSize.Z)
                    local es=baseSize*State.Hitbox.HRPMultiplier
                    pcall(function() entry.hrpPart.Size=Vector3.new(es,es,es) end)
                end
            end
        end
    end})
HitboxTab:CreateSlider({Name="HRP Transparency",Range={0,100},Increment=1,Suffix="%",CurrentValue=100,
    StateGet=function() return math.floor(State.Hitbox.HRPTransparency*100+0.5) end,
    Callback=function(v)
        State.Hitbox.HRPTransparency=v/100
        if State.Hitbox.Enabled and State.Hitbox.HRPEnabled then
            for _,entry in pairs(HitboxData) do
                if entry.hrpPart and entry.hrpPart.Parent then
                    pcall(function() entry.hrpPart.Transparency=State.Hitbox.HRPTransparency end)
                end
            end
        end
    end})
do
    local partDefs={{"Head","Head"},{"Torso  (R6 / R15)","Torso"},{"HumanoidRootPart","HumanoidRootPart"},
        {"Right Arm","Right Arm"},{"Left Arm","Left Arm"},{"Right Leg","Right Leg"},{"Left Leg","Left Leg"}}
    for _,def in ipairs(partDefs) do
        local dn,sk=def[1],def[2]
        HitboxTab:CreateToggle({Name=dn,CurrentValue=State.Hitbox.Parts[sk] or false,
            StateGet=function() return State.Hitbox.Parts[sk] or false end,
            Callback=function(v)
                State.Hitbox.Parts[sk]=v
                if sk=="Torso" then State.Hitbox.Parts["UpperTorso"]=v end
                if State.Hitbox.Enabled then ClearAllHitboxes(); SetupHitbox() end
            end})
    end
end

