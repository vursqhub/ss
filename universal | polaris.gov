SwitchTab("Aimbot")
MainFrame.InputBegan:Connect(function(inp)
    if inp.UserInputType==Enum.UserInputType.MouseButton1 then
        local mp=UserInputService:GetMouseLocation()
        if not PointInAnyPopup(mp.X,mp.Y) then CloseAllPopups() end
    end
end)

UserInputService.InputChanged:Connect(function(inp)
    if not _activeSlide then return end
    if inp.UserInputType~=Enum.UserInputType.MouseMovement then return end
    local trk=_activeSlide.trk; if not trk or not trk.Parent then _activeSlide=nil; return end
    _activeSlide.sv((inp.Position.X-trk.AbsolutePosition.X)/trk.AbsoluteSize.X)
end)
UserInputService.InputEnded:Connect(function(inp)
    if inp.UserInputType==Enum.UserInputType.MouseButton1 then _activeSlide=nil end
end)

-- ============================================================
-- // FOV CIRCLE  (v2.7.7 – no caching)
-- ============================================================
-- FIX: All position/color caching removed. The previous version had 5 cache
-- variables (_fovVis, _fovR, _fovCX, _fovCY, _fovCol). The critical bug:
--   _fovCol was initialised to State.Aimbot.Color at declaration time, so on
--   the very first RenderStepped call, cc = (col ~= _fovCol) evaluated to
--   FALSE even though the Drawing lines had never received a color assignment
--   (Drawing.new("Line") defaults to white). The circle appeared white.
--   Additionally, after a config load changed State.Aimbot.FOV or Color,
--   the caching could suppress the update if the mouse hadn't moved.
-- The fix is unconditional per-frame writes. Cost: ~64 Vector2 constructors
-- per frame, well under 0.1 ms on any modern executor.

local FOV_SEGS=64; local FOVLines={}; local TWO_PI=math.pi*2
for i=1,FOV_SEGS do
    local ln=Drawing.new("Line"); ln.Visible=false; ln.Thickness=1
    FOVLines[i]=ln
end

local function UpdateFOVCircle(col, vis)
    if not vis then
        -- Only touch Visible if lines are currently shown (avoids redundant writes)
        for i=1,FOV_SEGS do
            if FOVLines[i].Visible then FOVLines[i].Visible=false end
        end
        return
    end
    local mp=UserInputService:GetMouseLocation()
    local cx, cy, r = mp.X, mp.Y, State.Aimbot.FOV
    for i=1,FOV_SEGS do
        local ln=FOVLines[i]
        local a1=(i-1)/FOV_SEGS*TWO_PI
        local a2=i/FOV_SEGS*TWO_PI
        ln.From  = Vector2.new(cx+math.cos(a1)*r, cy+math.sin(a1)*r)
        ln.To    = Vector2.new(cx+math.cos(a2)*r, cy+math.sin(a2)*r)
        ln.Color = col
        if not ln.Visible then ln.Visible=true end
    end
end

-- ============================================================
-- // TRIGGERBOT CROSSHAIR
-- ============================================================

local TBCircle=Drawing.new("Circle"); TBCircle.Visible=false; TBCircle.Color=Color3.fromRGB(255,255,255); TBCircle.Thickness=1; TBCircle.NumSides=40; TBCircle.Filled=false
local TBCrossH=Drawing.new("Line"); TBCrossH.Visible=false; TBCrossH.Color=Color3.fromRGB(255,255,255); TBCrossH.Thickness=1
local TBCrossV=Drawing.new("Line"); TBCrossV.Visible=false; TBCrossV.Color=Color3.fromRGB(255,255,255); TBCrossV.Thickness=1
local TBDot=Drawing.new("Circle"); TBDot.Visible=false; TBDot.Color=Color3.fromRGB(255,255,255); TBDot.Thickness=1; TBDot.Radius=2; TBDot.NumSides=12; TBDot.Filled=true

do
    local reg={}; for _,ln in ipairs(FOVLines) do table.insert(reg,ln) end
    table.insert(reg,TBCircle); table.insert(reg,TBCrossH); table.insert(reg,TBCrossV); table.insert(reg,TBDot)
    _G._PolarisDrawings=reg
end

local function UpdateTBCrosshair()
    if not State.Triggerbot.Enabled then TBCircle.Visible=false; TBCrossH.Visible=false; TBCrossV.Visible=false; TBDot.Visible=false; return end
    local cx,cy=_vpCenter.X,_vpCenter.Y; local r=State.Triggerbot.Radius; local csz=8
    TBCircle.Position=Vector2.new(cx,cy); TBCircle.Radius=r; TBCircle.Visible=true
    TBCrossH.From=Vector2.new(cx-csz,cy); TBCrossH.To=Vector2.new(cx+csz,cy); TBCrossH.Visible=true
    TBCrossV.From=Vector2.new(cx,cy-csz); TBCrossV.To=Vector2.new(cx,cy+csz); TBCrossV.Visible=true
    TBDot.Position=Vector2.new(cx,cy); TBDot.Visible=true
end

-- ============================================================
-- // MAIN RENDER LOOP
-- ============================================================

Conn("RenderMain", RunService.RenderStepped:Connect(function(dt)
    local cam=GetCamera()
    _vpCenter=Vector2.new(cam.ViewportSize.X*0.5,cam.ViewportSize.Y*0.5)
    _rainbowHueAimbot=(_rainbowHueAimbot+dt*State.Aimbot.RainbowSpeed)%1
    _rainbowHueESP=(_rainbowHueESP+dt*State.ESP.RainbowSpeed)%1
    local rainbowColAimbot=Color3.fromHSV(_rainbowHueAimbot,1,1)
    local rainbowColESP=Color3.fromHSV(_rainbowHueESP,1,1)
    UpdateFOVCircle(State.Aimbot.RainbowFOV and rainbowColAimbot or State.Aimbot.Color, State.Aimbot.Enabled)
    UpdateTBCrosshair()
    if State.Aimbot.Enabled then RunAimbot() end
    RunTriggerbot(dt)
    UpdateESP(rainbowColESP)
    _fpsCount=_fpsCount+1; _fpsAccum=_fpsAccum+dt; _wmAccum=_wmAccum+dt
    if _wmAccum>=0.5 then
        if _fpsAccum>0 then _fpsCached=math.floor(_fpsCount/_fpsAccum+0.5) end
        _fpsCount=0; _fpsAccum=0; _wmAccum=0
        local ping=math.floor(LocalPlayer:GetNetworkPing()*1000)
        WatermarkLabel.Text=string.format("universal | polaris.gov - v2.7.7  |  %d fps  |  %d ms",_fpsCached,ping)
    end
end))

Conn("LocUpdate", RunService.Heartbeat:Connect(function()
    local root=GetRoot(LocalPlayer); if root then
        local p=root.Position
        setLocX(string.format("%.2f",p.X)); setLocY(string.format("%.2f",p.Y)); setLocZ(string.format("%.2f",p.Z))
    end
end))

-- ============================================================
-- // PLAYER & CHARACTER EVENTS
-- ============================================================

Players.PlayerAdded:Connect(function(player)
    if State.ESP.Enabled then CreateESPForPlayer(player) end
    player.CharacterAdded:Connect(function()
        task.wait(0.5)
        if State.ESP.Enabled then local d=ESPObjects[player]; if d then d.lastChar=nil end end
        RestoreHitboxForPlayer(player)
        if State.Hitbox.Enabled then ApplyHitboxToPlayer(player) end
    end)
    if State.Hitbox.Enabled and player.Character then ApplyHitboxToPlayer(player) end
end)

for _, player in ipairs(Players:GetPlayers()) do
    if player ~= LocalPlayer then
        player.CharacterAdded:Connect(function()
            task.wait(0.5)
            if State.ESP.Enabled then local d=ESPObjects[player]; if d then d.lastChar=nil end end
            RestoreHitboxForPlayer(player)
            if State.Hitbox.Enabled then ApplyHitboxToPlayer(player) end
        end)
    end
end

Players.PlayerRemoving:Connect(function(player)
    local d=ESPObjects[player]; if d then DestroyESPEntry(d); ESPObjects[player]=nil end
    RestoreHitboxForPlayer(player)
end)

Mouse.Button1Down:Connect(function()
    local root=GetRoot(LocalPlayer); if not root then return end
    if State.Movement.ClickTP then
        root.CFrame=CFrame.new(Mouse.Hit.Position+Vector3.new(0,3,0))
    elseif State.Movement.ClickTweenTP and not TweenTPActive then
        TweenTPActive=true
        local tgt=Mouse.Hit.Position+Vector3.new(0,3,0)
        local dist=(tgt-root.Position).Magnitude
        local tt=math.max(0.05,dist/(State.Movement.ClickTweenTPSpeed*20))
        local tw=TweenService:Create(root,TweenInfo.new(tt,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{CFrame=CFrame.new(tgt)})
        root.Anchored=true; tw:Play(); tw.Completed:Connect(function() root.Anchored=false; TweenTPActive=false end)
    end
end)

LocalPlayer.CharacterAdded:Connect(OnCharacterAdded)

-- ============================================================
-- // STARTUP
-- ============================================================

local _openSound=Instance.new("Sound"); _openSound.Name="PolarisOpen"
_openSound.SoundId="rbxassetid://140528689236462"; _openSound.Volume=1; _openSound.Looped=false
_openSound.Parent=SoundService; _openSound:Play(); game:GetService("Debris"):AddItem(_openSound,30)

do
    local ls=New("Frame",{Size=UDim2.fromScale(1,1),BackgroundColor3=Color3.fromRGB(8,8,14),ZIndex=999,Parent=ScreenGui})
    New("TextLabel",{Size=UDim2.new(1,0,0,48),Position=UDim2.new(0,0,0.38,0),BackgroundTransparency=1,
        Text="polaris.gov",Font=Enum.Font.GothamBold,TextSize=36,TextColor3=C.Accent,
        TextXAlignment=Enum.TextXAlignment.Center,ZIndex=1000,Parent=ls})
    New("TextLabel",{Size=UDim2.new(1,0,0,28),Position=UDim2.new(0,0,0.38,52),BackgroundTransparency=1,
        Text="Welcome, "..LocalPlayer.DisplayName.."  ·  universal v2.7.7",Font=Enum.Font.Gotham,TextSize=14,
        TextColor3=C.TextDim,TextXAlignment=Enum.TextXAlignment.Center,ZIndex=1000,Parent=ls})
    local barBG=New("Frame",{Size=UDim2.fromOffset(260,3),Position=UDim2.new(0.5,-130,0.38,92),
        BackgroundColor3=C.SliderBG,BorderSizePixel=0,ZIndex=1000,Parent=ls},{New("UICorner",{CornerRadius=UDim.new(1,0)})})
    local barFil=New("Frame",{Size=UDim2.fromOffset(0,3),BackgroundColor3=C.Accent,BorderSizePixel=0,ZIndex=1001,Parent=barBG},
        {New("UICorner",{CornerRadius=UDim.new(1,0)})})
    Tween(barFil,TweenInfo.new(4.5,Enum.EasingStyle.Quad,Enum.EasingDirection.Out),{Size=UDim2.fromOffset(260,3)})
    task.delay(5.0,function()
        local fi=TweenInfo.new(0.6,Enum.EasingStyle.Quad)
        Tween(ls,fi,{BackgroundTransparency=1})
        for _,c in ipairs(ls:GetDescendants()) do
            if c:IsA("TextLabel") then Tween(c,fi,{TextTransparency=1}) end
            if c:IsA("Frame") then Tween(c,fi,{BackgroundTransparency=1}) end
        end
        task.wait(0.7); if ls and ls.Parent then ls:Destroy() end
    end)
end

PolarisNotify("polaris.gov","universal v2.7.7 loaded",4)
print("[polaris.gov] universal v2.7.7 loaded")
