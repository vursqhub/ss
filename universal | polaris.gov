ESPTab:CreateToggle({Name="Team Check",CurrentValue=false,Callback=function(v) State.ESP.TeamCheck=v end})
do
    ESPTab:CreateLabel("Team Mode:")
    local ms=Tabs["ESP"].Scroll; local modeBtns={}
    local function SelESPTeamMode(mode)
        State.ESP.TeamMode=mode
        for m,b in pairs(modeBtns) do Tween(b,T_FAST,{BackgroundColor3=m==mode and C.AccentDim or C.Element}) end
    end
    local function MkTeamBtn(lbl,modeKey,lo)
        local b=New("TextButton",{Size=UDim2.new(1,0,0,30),
            BackgroundColor3=modeKey=="hide" and C.AccentDim or C.Element,
            BorderSizePixel=0,LayoutOrder=lo,Text=lbl,Font=Enum.Font.Gotham,TextSize=11,
            TextColor3=C.Text,Parent=ms},{New("UICorner",{CornerRadius=UDim.new(0,6)})})
        modeBtns[modeKey]=b; b.MouseButton1Click:Connect(function() SelESPTeamMode(modeKey) end)
        b.MouseEnter:Connect(function() if State.ESP.TeamMode~=modeKey then Tween(b,T_FAST,{BackgroundColor3=C.ElemHov}) end end)
        b.MouseLeave:Connect(function() if State.ESP.TeamMode~=modeKey then Tween(b,T_FAST,{BackgroundColor3=C.Element}) end end)
    end
    local to=Tabs["ESP"].Order; MkTeamBtn("Mode: Hide teammates","hide",to+1); MkTeamBtn("Mode: Color + TEAM label","color",to+2)
    Tabs["ESP"].Order=to+2
    RegisterSetter(
        function() return State.ESP.TeamMode end,
        function(v)
            for m,b in pairs(modeBtns) do
                pcall(function() b.BackgroundColor3 = (m==v) and C.AccentDim or C.Element end)
            end
        end
    )
end
ESPTab:CreateColorPicker({Name="Team Color",Color=Color3.fromRGB(0,255,120),NoRainbow=true,
