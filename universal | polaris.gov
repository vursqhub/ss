-- // universal | polaris.gov
-- // Version: 2.7.7
-- ============================================================
-- CHANGELOG vs 2.7.6:
--   FIX  FOV CIRCLE: Removed position/color caching entirely.
--         The cache caused two bugs: (1) Drawing lines default to white —
--         since _fovCol was init'd to State.Aimbot.Color, cc=false on first
--         render, so lines never received their configured color.
--         (2) After a config load, if the FOV or color matched the cached
--         value, the circle silently refused to update. Now all 64 segments
--         are written unconditionally every RenderStepped frame. The per-
--         frame cost is negligible (~0.01 ms).
--   FIX  HITBOX RE-INJECTION: Original part sizes are now stored in
--         _G._PolarisHitboxData before expansion and restored in the
--         re-injection cleanup block. Previously the cleanup comment said
--         "sizes restored when ClearAllHitboxes() is called on re-inject"
--         but ClearAllHitboxes() was never called in the cleanup block.
--         The new script's empty HitboxData table meant expanded parts had
--         their expanded size stored as "original", causing double-expansion
--         on each successive injection.
--   FIX  KEYBIND: CreateKeybind now accepts StateGet and registers with
--         GUISetters so SyncGUI (called after config load) can update the
--         displayed key label.
--   FIX  COLOR PICKER: CreateColorPicker now accepts ColorStateGet and
--         registers with GUISetters so the swatch BackgroundColor3 reflects
--         the value loaded from a config.
-- ============================================================

-- ============================================================
-- // RE-INJECTION CLEANUP
-- ============================================================
do
    local _cgOk2, _cg2 = pcall(function() return game:GetService("CoreGui") end)
    local _root = (_cgOk2 and _cg2) and _cg2 or game:GetService("Players").LocalPlayer:FindFirstChild("PlayerGui")
    if _root then
        for _, name in ipairs({"PolarisGUI","PolarisWatermark"}) do
            local old = _root:FindFirstChild(name)
            if old then old:Destroy() end
        end
    end
    local pg = game:GetService("Players").LocalPlayer:FindFirstChild("PlayerGui")
    if pg then
        for _, name in ipairs({"PolarisGUI","PolarisWatermark"}) do
            local old = pg:FindFirstChild(name)
            if old then old:Destroy() end
        end
    end

    if _G._PolarisDrawings then
        for _, d in ipairs(_G._PolarisDrawings) do
            pcall(function() d:Remove() end)
        end
        _G._PolarisDrawings = nil
    end

    -- FIX: Restore hitbox part sizes from previous injection.
    -- _G._PolarisHitboxData is a flat array of {part, origSize, origTrans, isHRP}.
    -- Without this, the new script's empty HitboxData stores already-expanded
    -- sizes as "originals", causing double-expansion on every re-inject.
    if _G._PolarisHitboxData then
        for _, e in ipairs(_G._PolarisHitboxData) do
            pcall(function()
                if e.part and e.part.Parent then
                    e.part.Size = e.origSize
                    if e.origTrans ~= nil then
                        e.part.Transparency = e.origTrans
                    end
                end
            end)
        end
        _G._PolarisHitboxData = nil
    end

    local _ss = game:GetService("SoundService")
    local _oldMusic = _ss:FindFirstChild("PolarisMusic")
    if _oldMusic then _oldMusic:Destroy() end
end

-- ============================================================
