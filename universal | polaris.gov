-- ============================================================
-- // AIMBOT ENGINE
-- ============================================================

local function RaycastVisible(targetPart)
    local char = GetCharacter(LocalPlayer)
    local head = char and char:FindFirstChild("Head")
    if not head then return false end

    local origin    = head.Position
    local targetPos = targetPart.Position
    local direction = targetPos - origin
    local distance  = direction.Magnitude
    if distance < 0.1 then return true end
    local dirUnit   = direction.Unit

    local excluded = { char }
    local traveled = 0
    local MAX_ITER = 20

    for _ = 1, MAX_ITER do
        local rp = RaycastParams.new()
        rp.FilterDescendantsInstances = excluded
        rp.FilterType                 = Enum.RaycastFilterType.Exclude
        local res = workspace:Raycast(origin + dirUnit * traveled,
                                      dirUnit * (distance - traveled), rp)
        if not res then return true end
        local hit = res.Instance
        if not hit.CanCollide then
            table.insert(excluded, hit)
            traveled = (res.Position - origin).Magnitude + 0.05
            if traveled >= distance then return true end
        elseif hit:IsDescendantOf(targetPart.Parent) then
            return true
        else
            return false
        end
    end
    return false
end

local function IsTargetVisible(targetPart)
    if not State.Aimbot.WallCheck then return true end
    return RaycastVisible(targetPart)
end

local function GetPredPos(part, rootPart)
    local vel  = (State.Aimbot.Prediction and rootPart)
        and rootPart.AssemblyLinearVelocity or Vector3.zero
    local lead = State.Aimbot.Prediction and State.Aimbot.PredictionStrength or 0
    return part.Position + vel * lead
end

local function GetAimPart(char)
    if not char then return nil end
    local partName = State.Aimbot.TargetPart or "Head"
    local p = char:FindFirstChild(partName)
    if p and p:IsA("BasePart") then return p end
    if partName == "Torso" then
        return char:FindFirstChild("UpperTorso") or char:FindFirstChild("Torso")
    elseif partName == "Head" then
        return char:FindFirstChild("Head")
    end
    return char:FindFirstChild("HumanoidRootPart")
end

local function GetTargetSP(player, keepLocked)
    if not player or not IsAlive(player) then return nil end
    if State.Aimbot.TeamCheck and IsTeammate(player) then return nil end
    local char = GetCharacter(player)
    local aimPart = GetAimPart(char)
    local root    = char and char:FindFirstChild("HumanoidRootPart")
    if not aimPart then return nil end

    local pred    = GetPredPos(aimPart, root)
    local sp, on  = W2S(pred)
    if not on then return nil end

    if not keepLocked then
        local mousePos = UserInputService:GetMouseLocation()
        if (sp - mousePos).Magnitude > State.Aimbot.FOV then return nil end
    end

    if not IsTargetVisible(aimPart) then return nil end
    return sp
end

local function AimScanTarget()
    local mousePos       = UserInputService:GetMouseLocation()
    local best, bestDist = nil, math.huge
    for _, p in ipairs(Players:GetPlayers()) do
        if p ~= LocalPlayer and IsAlive(p)
        and not (State.Aimbot.TeamCheck and IsTeammate(p)) then
            local char    = GetCharacter(p)
            local aimPart = GetAimPart(char)
            local root    = char and char:FindFirstChild("HumanoidRootPart")
            if aimPart then
                local pred   = GetPredPos(aimPart, root)
                local sp, on = W2S(pred)
                if on then
                    local d = (sp - mousePos).Magnitude
                    if d < State.Aimbot.FOV and d < bestDist and IsTargetVisible(aimPart) then
                        bestDist = d; best = p
                    end
                end
            end
        end
    end
    return best
end

local function IsAimKeyActive()
    local k = State.Aimbot.LockKey
    if k == "MouseButton2" then
        return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton2)
    elseif k == "MouseButton1" then
        return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton1)
    elseif k == "MouseButton3" then
        return UserInputService:IsMouseButtonPressed(Enum.UserInputType.MouseButton3)
    else
        local ok, kc = pcall(function() return Enum.KeyCode[k] end)
        if ok and kc then return UserInputService:IsKeyDown(kc) end
    end
    return false
end

local PolarisNotify  -- forward declaration

local function RunAimbot()
    if not State.Aimbot.Enabled then return end

    local keyHeld = IsAimKeyActive()
    if not keyHeld then
        LockedTarget = nil
        _lastTargetName = ""; _lastTargetHP = nil; _totalDamage = 0
        return
    end

    local stayLocked = State.Aimbot.KeepLocked
    local sp = GetTargetSP(LockedTarget, stayLocked)
    if not sp then
        LockedTarget = AimScanTarget()
        if LockedTarget then
            sp = GetTargetSP(LockedTarget, false)
            if LockedTarget then
                local name = LockedTarget.DisplayName or LockedTarget.Name
                if name ~= _lastTargetName then
                    _lastTargetName = name
                    _lastTargetHP   = nil
                    _totalDamage    = 0
                    PolarisNotify("Aimbot", "Tracking: " .. name, 2)
                end
            end
        end
    end
    if not LockedTarget or not sp then return end

    local hum = GetHumanoid(LockedTarget)
    if hum then
        local curHP = hum.Health
        if _lastTargetHP ~= nil and curHP < _lastTargetHP then
            local dmg = _lastTargetHP - curHP
            _totalDamage = _totalDamage + dmg
            PolarisNotify("Hit", string.format("%s  −%.0f hp  (total %.0f)", _lastTargetName, dmg, _totalDamage), 1.5)
        end
        _lastTargetHP = curHP
    end

    local char    = GetCharacter(LockedTarget)
    local aimPart = GetAimPart(char)
    local root    = char and char:FindFirstChild("HumanoidRootPart")
    if not aimPart then LockedTarget = nil; return end

    local aimPos  = GetPredPos(aimPart, root)
    local smooth  = math.clamp(State.Aimbot.Smoothness, 0.01, 1)
    local camCF   = GetCamera().CFrame
    local dir     = (aimPos - camCF.Position).Unit
    local tgtCF   = CFrame.new(camCF.Position, camCF.Position + dir)
    GetCamera().CFrame = camCF:Lerp(tgtCF, smooth)
end

local function SetupAimbot()
    LockedTarget = nil
end

-- ============================================================
-- // ESP
-- ============================================================

local function GetSkelPairs(char)
    if char:FindFirstChild("UpperTorso") then
        return {
            {"Head","UpperTorso"},
            {"UpperTorso","LowerTorso"},
            {"UpperTorso","RightUpperArm"},{"RightUpperArm","RightLowerArm"},{"RightLowerArm","RightHand"},
            {"UpperTorso","LeftUpperArm"}, {"LeftUpperArm","LeftLowerArm"},  {"LeftLowerArm","LeftHand"},
            {"LowerTorso","RightUpperLeg"},{"RightUpperLeg","RightLowerLeg"},{"RightLowerLeg","RightFoot"},
            {"LowerTorso","LeftUpperLeg"}, {"LeftUpperLeg","LeftLowerLeg"},  {"LeftLowerLeg","LeftFoot"},
        }
    else
        return {
            {"Head","Torso"},
            {"Torso","Left Arm"},{"Torso","Right Arm"},
            {"Torso","Left Leg"},{"Torso","Right Leg"},
        }
    end
end

local function RebuildSkeleton(d, char)
    for _, s in ipairs(d.Skeleton) do pcall(function() s.line:Remove() end) end
    d.Skeleton = {}
    d.lastChar = char
    for _, pair in ipairs(GetSkelPairs(char)) do
        local ln     = Drawing.new("Line")
        ln.Visible   = false
        ln.Color     = State.ESP.Color
        ln.Thickness = 1
        table.insert(d.Skeleton, { line = ln, parts = pair })
    end
end

local function ClearESPEntry(d)
    pcall(function() d.Box.Visible       = false end)
    pcall(function() d.Name.Visible      = false end)
    pcall(function() d.Distance.Visible  = false end)
    pcall(function() d.Tracer.Visible    = false end)
    pcall(function() d.TeamLabel.Visible = false end)
    pcall(function() if d.Highlight.Parent ~= nil then d.Highlight.Parent = nil end end)
    for _, s in ipairs(d.Skeleton) do pcall(function() s.line.Visible = false end) end
end

local function DestroyESPEntry(d)
    ClearESPEntry(d)
    pcall(function() d.Box:Remove()       end)
    pcall(function() d.Name:Remove()      end)
    pcall(function() d.Distance:Remove()  end)
    pcall(function() d.Tracer:Remove()    end)
    pcall(function() d.TeamLabel:Remove() end)
    pcall(function() d.Highlight:Destroy() end)
    for _, s in ipairs(d.Skeleton) do pcall(function() s.line:Remove() end) end
end

local function ClearAllESP()
    for _, d in pairs(ESPObjects) do DestroyESPEntry(d) end
    ESPObjects = {}
end

local function CreateESPForPlayer(player)
    if player == LocalPlayer then return end
    if ESPObjects[player] then return end
    local col = State.ESP.Color
    local d   = {}

    d.Box              = Drawing.new("Square")
    d.Box.Visible      = false
    d.Box.Color        = col
    d.Box.Thickness    = 1
    d.Box.Filled       = false

    d.Name             = Drawing.new("Text")
    d.Name.Visible     = false
    d.Name.Color       = col
    d.Name.Size        = 14
    d.Name.Center      = true
    d.Name.Outline     = true

    d.Distance         = Drawing.new("Text")
    d.Distance.Visible = false
    d.Distance.Color   = col
    d.Distance.Size    = 12
    d.Distance.Center  = true
    d.Distance.Outline = true

    d.Tracer           = Drawing.new("Line")
    d.Tracer.Visible   = false
    d.Tracer.Color     = col
    d.Tracer.Thickness = 1

    d.Highlight                     = Instance.new("Highlight")
    d.Highlight.FillTransparency    = 0.5
    d.Highlight.OutlineTransparency = 0
    d.Highlight.FillColor           = col
    d.Highlight.OutlineColor        = col

    d.TeamLabel         = Drawing.new("Text")
    d.TeamLabel.Visible = false
    d.TeamLabel.Color   = State.ESP.TeamColor
    d.TeamLabel.Size    = 13
    d.TeamLabel.Center  = true
    d.TeamLabel.Outline = true
    d.TeamLabel.Text    = "TEAM"

    d.Skeleton  = {}
    d.lastChar  = nil
    d.lastColor = col

    ESPObjects[player] = d
end

local function SetupESP()
    ClearAllESP()
    if not State.ESP.Enabled then return end
    for _, p in ipairs(Players:GetPlayers()) do CreateESPForPlayer(p) end
end

local function UpdateESPPlayer(player, d, selfRoot, rainbowCol)
    pcall(function() d.Box.Visible       = false end)
    pcall(function() d.Name.Visible      = false end)
    pcall(function() d.Distance.Visible  = false end)
    pcall(function() d.Tracer.Visible    = false end)
    pcall(function() d.TeamLabel.Visible = false end)
    for _, s in ipairs(d.Skeleton) do pcall(function() s.line.Visible = false end) end

    local char = GetCharacter(player)
    local root, hum, head
    if char then
        root = char:FindFirstChild("HumanoidRootPart")
        hum  = char:FindFirstChildOfClass("Humanoid")
        head = char:FindFirstChild("Head")
    end

    local alive  = char ~= nil and root ~= nil and hum ~= nil and hum.Health > 0
    local isTeam = State.ESP.TeamCheck and IsTeammate(player)

    if isTeam then
        if State.ESP.TeamMode == "hide" then
            pcall(function() if d.Highlight.Parent ~= nil then d.Highlight.Parent = nil end end)
            return
        end
    end

    if not alive then
        pcall(function() if d.Highlight.Parent ~= nil then d.Highlight.Parent = nil end end)
        return
    end
    if char ~= d.lastChar then RebuildSkeleton(d, char) end

    local col
    if isTeam then
        col = State.ESP.TeamColor
    elseif State.ESP.Rainbow then
        col = rainbowCol
    else
        col = State.ESP.Color
    end

    if col ~= d.lastColor or State.ESP.Rainbow then
        d.lastColor = col
        pcall(function()
            d.Box.Color              = col
            d.Name.Color             = col
            d.Distance.Color         = col
            d.Tracer.Color           = col
            d.Highlight.FillColor    = col
            d.Highlight.OutlineColor = col
            for _, s in ipairs(d.Skeleton) do s.line.Color = col end
        end)
    end

    local rootPos    = root.Position
    local headPos    = head and head.Position or (rootPos + Vector3.new(0, 2.5, 0))
    local feetPos    = rootPos - Vector3.new(0, 3, 0)
    local headTopPos = headPos + Vector3.new(0, 0.6, 0)

    local rootSP,    rootOn = W2S(rootPos)
    local headSP,    headOn = W2S(headPos)
    local feetSP,    _      = W2S(feetPos)
    local headTopSP, _      = W2S(headTopPos)

    if not rootOn then
        pcall(function() if d.Highlight.Parent ~= nil then d.Highlight.Parent = nil end end)
        return
    end
    if State.ESP.MaxDist > 0 and selfRoot then
        if (selfRoot.Position - rootPos).Magnitude > State.ESP.MaxDist then
            pcall(function() if d.Highlight.Parent ~= nil then d.Highlight.Parent = nil end end)
            return
        end
    end

    pcall(function()
        if State.ESP.Highlight and not isTeam then
            if d.Highlight.Parent ~= char then d.Highlight.Parent = char end
        else
            if d.Highlight.Parent ~= nil then d.Highlight.Parent = nil end
        end
    end)

    if isTeam and State.ESP.TeamMode == "color" then
        pcall(function()
            d.TeamLabel.Color    = State.ESP.TeamColor
            d.TeamLabel.Position = Vector2.new(rootSP.X, (headOn and headSP.Y or rootSP.Y - 30) - 32)
            d.TeamLabel.Visible  = true
        end)
    end

    if State.ESP.Box then
        pcall(function()
            local topY = math.min(headTopSP.Y, feetSP.Y)
            local botY = math.max(headTopSP.Y, feetSP.Y)
            local sy   = math.max(botY - topY, 4)
            local sx   = math.max(sy * 0.45, 4)
            d.Box.Size     = Vector2.new(sx, sy)
            d.Box.Position = Vector2.new(rootSP.X - sx * 0.5, topY)
            d.Box.Visible  = true
        end)
    end

    if State.ESP.Names then
        pcall(function()
            d.Name.Text     = player.DisplayName
            d.Name.Position = Vector2.new(rootSP.X, (headOn and headSP.Y or rootSP.Y - 30) - 18)
            d.Name.Visible  = true
        end)
    end

    if State.ESP.Distance then
        pcall(function()
            local dist      = selfRoot and math.floor((selfRoot.Position - rootPos).Magnitude) or 0
            d.Distance.Text     = tostring(dist) .. " studs"
            d.Distance.Position = Vector2.new(rootSP.X, math.max(feetSP.Y, rootSP.Y) + 4)
            d.Distance.Visible  = true
        end)
    end

    if State.ESP.Tracer then
        pcall(function()
            d.Tracer.From    = Vector2.new(_vpCenter.X, _vpCenter.Y * 2)
            d.Tracer.To      = feetSP
            d.Tracer.Visible = true
        end)
    end

    if State.ESP.Skeleton then
        for _, s in ipairs(d.Skeleton) do
            pcall(function()
                local p1 = char:FindFirstChild(s.parts[1])
                local p2 = char:FindFirstChild(s.parts[2])
                if p1 and p2 then
                    local s1, on1 = W2S(p1.Position)
                    local s2, on2 = W2S(p2.Position)
                    if on1 and on2 then
                        s.line.From    = s1
                        s.line.To      = s2
                        s.line.Visible = true
                    end
                end
            end)
        end
    end
end

local function UpdateESP(rainbowCol)
    local selfRoot = GetRoot(LocalPlayer)
    if not State.ESP.Enabled then
        for _, d in pairs(ESPObjects) do ClearESPEntry(d) end
        return
    end
    for player, d in pairs(ESPObjects) do
        pcall(UpdateESPPlayer, player, d, selfRoot, rainbowCol)
    end
end

-- ============================================================
-- // VISUALS
-- ============================================================

local function SetAtmo(a, vals)
    if not a then return end
    if vals.Density  ~= nil then pcall(function() a.Density  = vals.Density  end) end
    if vals.Haze     ~= nil then pcall(function() a.Haze     = vals.Haze     end) end
    if vals.Glare    ~= nil then pcall(function() a.Glare    = vals.Glare    end) end
    if vals.FogBlend ~= nil then pcall(function() a.FogBlend = vals.FogBlend end) end
end

local function SetupFullbright()
    if State.Fullbright then
        Lighting.Ambient        = Color3.fromRGB(255,255,255)
        Lighting.OutdoorAmbient = Color3.fromRGB(255,255,255)
        Lighting.Brightness     = 2
        Lighting.GlobalShadows  = false
        SetAtmo(Lighting:FindFirstChildOfClass("Atmosphere"), {Density=0,Haze=0,Glare=0,FogBlend=0})
        for _, fx in ipairs(Lighting:GetChildren()) do
            if fx:IsA("PostEffect") then fx.Enabled = false end
        end
    else
        Lighting.Ambient        = LDefault.Ambient
        Lighting.OutdoorAmbient = LDefault.OutdoorAmbient
        Lighting.Brightness     = LDefault.Brightness
        if not State.NoShadows then Lighting.GlobalShadows = LDefault.GlobalShadows end
        local a = Lighting:FindFirstChildOfClass("Atmosphere")
        if a and next(AtmoDefault) then SetAtmo(a, AtmoDefault) end
        for fx, was in pairs(PostFXSaved) do pcall(function() fx.Enabled = was end) end
        if State.NoFog then
            SetAtmo(Lighting:FindFirstChildOfClass("Atmosphere"), {Density=0,Haze=0,FogBlend=0})
        end
    end
end

local function SetupNoFog()
    if State.NoFog then
        Lighting.FogEnd   = 1e9
        Lighting.FogStart = 1e9
        SetAtmo(Lighting:FindFirstChildOfClass("Atmosphere"), {Density=0,Haze=0,FogBlend=0})
    else
        Lighting.FogEnd   = LDefault.FogEnd
        Lighting.FogStart = LDefault.FogStart
        if not State.Fullbright then
            local a = Lighting:FindFirstChildOfClass("Atmosphere")
            if a and next(AtmoDefault) then SetAtmo(a, AtmoDefault) end
        end
    end
end

local function SetupNoShadows()
    Lighting.GlobalShadows = not State.NoShadows and LDefault.GlobalShadows or false
end

local function SetupFPSBoost()
    Drop("FPSParticle")
    if State.FPSBoost then
        Lighting.GlobalShadows = false
        pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Level01 end)
        pcall(function()
            local ugs = game:GetService("UserGameSettings")
            ugs.SavedQualityLevel = Enum.SavedQualitySetting.QualityLevel1
        end)
        FPSParticleCache = {}
        for _, fx in ipairs(Lighting:GetDescendants()) do
            if fx:IsA("PostEffect") then
                FPSParticleCache[fx] = fx.Enabled
                pcall(function() fx.Enabled = false end)
            end
        end
        for _, v in ipairs(workspace:GetDescendants()) do
            if v:IsA("ParticleEmitter") or v:IsA("Fire")
            or v:IsA("Smoke")           or v:IsA("Sparkles")
            or v:IsA("Trail") then
                FPSParticleCache[v] = v.Enabled
                pcall(function() v.Enabled = false end)
            end
            if v:IsA("SurfaceAppearance") then
                FPSParticleCache[v] = v.Parent
                pcall(function() v.Parent = nil end)
            end
        end
        local atmo = Lighting:FindFirstChildOfClass("Atmosphere")
        if atmo then FPSParticleCache[atmo] = atmo.Parent; pcall(function() atmo.Parent = nil end) end
        local sky = Lighting:FindFirstChildOfClass("Sky")
        if sky then FPSParticleCache[sky] = sky.Parent; pcall(function() sky.Parent = nil end) end
        Conn("FPSParticle", workspace.DescendantAdded:Connect(function(v)
            if not State.FPSBoost then return end
            if v:IsA("ParticleEmitter") or v:IsA("Fire") or v:IsA("Smoke")
            or v:IsA("Sparkles")        or v:IsA("Trail") then
                task.defer(function()
                    if State.FPSBoost and v and v.Parent then
                        FPSParticleCache[v] = v.Enabled; pcall(function() v.Enabled = false end)
                    end
                end)
            end
            if v:IsA("SurfaceAppearance") then
                task.defer(function()
                    if State.FPSBoost and v and v.Parent then
                        FPSParticleCache[v] = v.Parent; pcall(function() v.Parent = nil end)
                    end
                end)
            end
        end))
    else
        pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic end)
        pcall(function()
            local ugs = game:GetService("UserGameSettings")
            ugs.SavedQualityLevel = Enum.SavedQualitySetting.Automatic
        end)
        if not State.NoShadows then Lighting.GlobalShadows = LDefault.GlobalShadows end
        for v, was in pairs(FPSParticleCache) do
            pcall(function()
                if not v then return end
                if typeof(was) == "Instance" then
                    if v and not v.Parent then v.Parent = was end
                elseif v.Parent then
                    v.Enabled = was
                end
            end)
        end
        FPSParticleCache = {}
    end
end

-- ============================================================
-- // MOVEMENT
-- ============================================================

local function SetupTPWalk()
    Drop("TPWalk")
    if not State.Movement.TPWalk then return end
    if State.Movement.TPWalkTween then
        Conn("TPWalk", RunService.Heartbeat:Connect(function(dt)
            local root = GetRoot(LocalPlayer); local hum = GetHumanoid(LocalPlayer)
            if not root or not hum then return end
            local md = hum.MoveDirection; if md.Magnitude < 0.1 then return end
            local flat = Vector3.new(md.X, 0, md.Z)
            if flat.Magnitude < 0.01 then flat = md end
            local tp = TweenService:Create(root, TweenInfo.new(dt, Enum.EasingStyle.Linear),
                { CFrame = CFrame.new(root.Position + md * State.Movement.TPWalkSpeed * dt,
                    root.Position + md * State.Movement.TPWalkSpeed * dt + flat.Unit) })
            tp:Play()
        end))
    else
        Conn("TPWalk", RunService.Heartbeat:Connect(function()
            local root = GetRoot(LocalPlayer); local hum = GetHumanoid(LocalPlayer)
            if not root or not hum then return end
            local md = hum.MoveDirection; if md.Magnitude < 0.1 then return end
            local flat = Vector3.new(md.X, 0, md.Z)
            if flat.Magnitude < 0.01 then flat = md end
            local tp = root.Position + md * State.Movement.TPWalkSpeed * 0.05
            root.CFrame = CFrame.new(tp, tp + flat.Unit)
        end))
    end
end

local function ApplyWalkSpeed()
    local h = GetHumanoid(LocalPlayer); if not h then return end
    h.WalkSpeed = State.Movement.WalkSpeed and State.Movement.WalkSpeedValue or Defaults.WalkSpeed
end

local function SetupFly()
    Drop("Fly")
    local char = GetCharacter(LocalPlayer); local root = GetRoot(LocalPlayer); local hum = GetHumanoid(LocalPlayer)
    if not char or not root or not hum then return end
    local bv = root:FindFirstChild("FlyBV"); if bv then bv:Destroy() end
    local bg = root:FindFirstChild("FlyBG"); if bg then bg:Destroy() end
    if not State.Movement.Fly then hum.PlatformStand = false; return end
    hum.PlatformStand = true
    local bv2 = Instance.new("BodyVelocity"); bv2.Name="FlyBV"; bv2.Velocity=Vector3.zero
    bv2.MaxForce=Vector3.new(1e9,1e9,1e9); bv2.Parent=root
    local bg2 = Instance.new("BodyGyro"); bg2.Name="FlyBG"; bg2.MaxTorque=Vector3.new(1e9,1e9,1e9)
    bg2.P=1e4; bg2.CFrame=GetCamera().CFrame; bg2.Parent=root
    Conn("Fly", RunService.Heartbeat:Connect(function()
        local r=GetRoot(LocalPlayer); if not r then return end
        local v=r:FindFirstChild("FlyBV"); local g=r:FindFirstChild("FlyBG"); if not v or not g then return end
        local cam=GetCamera(); local d=Vector3.zero
        if UserInputService:IsKeyDown(Enum.KeyCode.W)           then d=d+cam.CFrame.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.S)           then d=d-cam.CFrame.LookVector  end
        if UserInputService:IsKeyDown(Enum.KeyCode.A)           then d=d-cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.D)           then d=d+cam.CFrame.RightVector end
        if UserInputService:IsKeyDown(Enum.KeyCode.Space)       then d=d+Vector3.new(0,1,0)    end
        if UserInputService:IsKeyDown(Enum.KeyCode.LeftControl) then d=d-Vector3.new(0,1,0)    end
        v.Velocity = d.Magnitude>0 and (d.Unit*State.Movement.FlySpeed) or Vector3.zero
        g.CFrame   = cam.CFrame
    end))
end

local SpinBAV = nil
local function SetupSpin()
    Drop("Spin")
    if SpinBAV then pcall(function() SpinBAV:Destroy() end); SpinBAV=nil end
    if not State.Movement.Spin then return end
    local root = GetRoot(LocalPlayer)
    if not root then
        Conn("Spin", RunService.Heartbeat:Connect(function()
            local r=GetRoot(LocalPlayer); if not r then return end
            Drop("Spin")
            if SpinBAV then pcall(function() SpinBAV:Destroy() end); SpinBAV=nil end
            local bav=Instance.new("BodyAngularVelocity")
            bav.AngularVelocity=Vector3.new(0,math.rad(State.Movement.SpinSpeed)*60,0)
            bav.MaxTorque=Vector3.new(0,math.huge,0); bav.P=math.huge; bav.Parent=r; SpinBAV=bav
            Conn("Spin", RunService.Heartbeat:Connect(function()
                if not State.Movement.Spin then return end
                if SpinBAV and SpinBAV.Parent then
                    SpinBAV.AngularVelocity=Vector3.new(0,math.rad(State.Movement.SpinSpeed)*60,0) end
            end))
        end)); return
    end
    local bav=Instance.new("BodyAngularVelocity")
    bav.AngularVelocity=Vector3.new(0,math.rad(State.Movement.SpinSpeed)*60,0)
    bav.MaxTorque=Vector3.new(0,math.huge,0); bav.P=math.huge; bav.Parent=root; SpinBAV=bav
    Conn("Spin", RunService.Heartbeat:Connect(function()
        if not State.Movement.Spin then return end
        if SpinBAV and SpinBAV.Parent then
            SpinBAV.AngularVelocity=Vector3.new(0,math.rad(State.Movement.SpinSpeed)*60,0) end
    end))
end

local function SetupInfJump()
    Drop("InfJump"); if not State.Movement.InfJump then return end
    Conn("InfJump", UserInputService.JumpRequest:Connect(function()
        local h=GetHumanoid(LocalPlayer); if h then h:ChangeState(Enum.HumanoidStateType.Jumping) end
    end))
end

local function SetupNoclip()
    Drop("Noclip")
    if not State.Movement.Noclip then
        for part in pairs(NoclipParts) do
            pcall(function() if part and part.Parent then part.CanCollide=true end end)
        end; NoclipParts={}; return
    end
    Conn("Noclip", RunService.Stepped:Connect(function()
        local char=GetCharacter(LocalPlayer); if not char then return end
        for _, p in ipairs(char:GetDescendants()) do
            if p:IsA("BasePart") and p.CanCollide then NoclipParts[p]=true; p.CanCollide=false end
        end
    end))
end

local function SetupGodMode()
    Drop("GodMode"); Drop("GodModeMax"); Drop("GodModeHB")
    if not State.Movement.GodMode then return end
    local h=GetHumanoid(LocalPlayer); if not h then return end
    pcall(function() h.MaxHealth=math.huge end); pcall(function() h.Health=math.huge end)
    pcall(function() h.BreakJointsOnDeath=false end)
    Conn("GodMode", h.HealthChanged:Connect(function()
        if State.Movement.GodMode then pcall(function() h.Health=h.MaxHealth end) end end))
    Conn("GodModeMax", h:GetPropertyChangedSignal("MaxHealth"):Connect(function()
        if State.Movement.GodMode then pcall(function() h.MaxHealth=math.huge; h.Health=math.huge end) end end))
    Conn("GodModeHB", RunService.Heartbeat:Connect(function()
        if not State.Movement.GodMode then return end
        local hum=GetHumanoid(LocalPlayer)
        if hum and hum.Health<hum.MaxHealth then pcall(function() hum.Health=hum.MaxHealth end) end
    end))
end

local function GetNearestPlayerRoot()
    local sr=GetRoot(LocalPlayer); if not sr then return nil end
    local best,bestD=nil,math.huge
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LocalPlayer then
            local r=GetRoot(p); if r then
                local d=(r.Position-sr.Position).Magnitude
                if d<bestD then bestD=d; best=r end
            end
        end
    end; return best
end

local function GetRandomPlayerRoot()
    local roots={}
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LocalPlayer then local r=GetRoot(p); if r then table.insert(roots,r) end end
    end
    if #roots==0 then return nil end; return roots[math.random(1,#roots)]
end

local function SetupOrbit()
    Drop("Orbit"); Drop("OrbitClick")
    OrbitTarget=nil; OrbitAngle=0; OrbitAutoTimer=0
    if not State.Movement.Orbit then return end
    if State.Movement.OrbitMode=="click" then
        Conn("OrbitClick", Mouse.Button1Down:Connect(function()
            if not State.Movement.Orbit then return end
            if State.Movement.ClickTP or State.Movement.ClickTweenTP then return end
            local hit=Mouse.Hit; if not hit then return end
            local best,bestD=nil,math.huge
            for _,p in ipairs(Players:GetPlayers()) do
                if p~=LocalPlayer then local r=GetRoot(p); if r then
                    local d=(r.Position-hit.Position).Magnitude
                    if d<8 and d<bestD then bestD=d; best=r end
                end end
            end
            if best then OrbitTarget=best; OrbitAngle=0 end
        end))
    end
    Conn("Orbit", RunService.Heartbeat:Connect(function(dt)
        local root=GetRoot(LocalPlayer); if not root then return end
        local mode=State.Movement.OrbitMode
        if mode=="nearest" then OrbitTarget=GetNearestPlayerRoot()
        elseif mode=="auto" then
            OrbitAutoTimer=OrbitAutoTimer+dt
            local gone=OrbitTarget==nil or not OrbitTarget.Parent
            if OrbitAutoTimer>=State.Movement.OrbitCooldown or gone then
                OrbitAutoTimer=0; OrbitTarget=GetRandomPlayerRoot()
            end
        end
        if not OrbitTarget then return end
        if not OrbitTarget.Parent then OrbitTarget=nil; return end
        OrbitAngle=OrbitAngle+math.rad(State.Movement.OrbitSpeed)*dt*60
        local rad=State.Movement.OrbitRadius
        local op=OrbitTarget.Position+Vector3.new(math.cos(OrbitAngle)*rad,0,math.sin(OrbitAngle)*rad)
        root.CFrame=CFrame.new(op,OrbitTarget.Position)
    end))
end

-- ============================================================
-- // TRIGGERBOT
-- ============================================================

local function SimulateLMBClick()
    if mouse1click then pcall(mouse1click)
    elseif mouse1press then pcall(mouse1press); task.delay(0.05,function() pcall(mouse1release) end) end
end

local function RunTriggerbot(dt)
    if not State.Triggerbot.Enabled then _tbWasInView=false; _tbSpamTimer=0; return end
    local inView=false; local radius=State.Triggerbot.Radius; local cx,cy=_vpCenter.X,_vpCenter.Y
    for _,p in ipairs(Players:GetPlayers()) do
        if p~=LocalPlayer and IsAlive(p) and not (State.Triggerbot.TeamCheck and IsTeammate(p)) then
            local char=GetCharacter(p); local head=char and char:FindFirstChild("Head")
            if head then
                local sp,on=W2S(head.Position)
                if on and (sp-Vector2.new(cx,cy)).Magnitude<=radius then
                    if not State.Triggerbot.WallCheck or RaycastVisible(head) then
                        inView=true; break
                    end
                end
            end
        end
    end
    if State.Triggerbot.Spam then
        if inView then
            _tbSpamTimer=_tbSpamTimer+dt
            if _tbSpamTimer>=State.Triggerbot.Delay then _tbSpamTimer=0; SimulateLMBClick() end
        else _tbSpamTimer=0 end
    else
        if inView and not _tbWasInView then SimulateLMBClick() end
    end
    _tbWasInView=inView
end

-- ============================================================
-- // HITBOX EXPANDER  (v2.7.7 – direct part resize + global tracking)
-- ============================================================

-- HitboxData[player] = { parts = {[part]=origSize}, hl = Highlight|nil, ... }
local HitboxData = {}

-- FIX: _G._PolarisHitboxData is a flat array of restore records so that
-- re-injection cleanup can restore expanded sizes before overwriting them.
-- Initialise to empty table if not already set by a previous injection.
_G._PolarisHitboxData = _G._PolarisHitboxData or {}

local function _HBGRegister(part, origSize, origTrans)
    -- Push a restore record into the global table.
    -- On re-injection the cleanup block reads this and restores before HitboxData
    -- is re-initialized. Duplicate entries are fine — restoring the same part
    -- twice with the same origSize is idempotent.
    table.insert(_G._PolarisHitboxData, { part = part, origSize = origSize, origTrans = origTrans })
end

local function ApplyHitboxToPlayer(player)
    if player == LocalPlayer then return end
    if State.Hitbox.TeamCheck and IsTeammate(player) then return end
    if HitboxData[player] then return end

    local char = GetCharacter(player)
    if not char then return end

    local expand = State.Hitbox.Size
    local entry  = { parts = {}, partOrigTrans = {}, hl = nil, hrpPart = nil, hrpOrigSize = nil, hrpOrigTrans = nil }
    local count  = 0

    for partName, enabled in pairs(State.Hitbox.Parts) do
        if enabled then
            local targets = { char:FindFirstChild(partName) }
            if partName == "Torso" then
                targets[#targets+1] = char:FindFirstChild("UpperTorso")
                targets[#targets+1] = char:FindFirstChild("LowerTorso")
            end
            for _, part in ipairs(targets) do
                if part and part:IsA("BasePart")
                and part.Name ~= "HumanoidRootPart"
                and not entry.parts[part] then
                    local origSize  = part.Size
                    local origTrans = part.Transparency
                    entry.parts[part]         = origSize
                    entry.partOrigTrans[part] = origTrans
                    -- Register for cross-injection restoration
                    _HBGRegister(part, origSize, origTrans)
                    pcall(function()
                        part.Size         = origSize + Vector3.new(expand, expand, expand) * 2
                        part.Transparency = State.Hitbox.Transparency
                    end)
                    count = count + 1
                end
            end
        end
    end

    if State.Hitbox.HRPEnabled then
        local hrp = char:FindFirstChild("HumanoidRootPart")
        if hrp and hrp:IsA("BasePart") then
            local origSize  = hrp.Size
            local origTrans = hrp.Transparency
            entry.hrpPart       = hrp
            entry.hrpOrigSize   = origSize
            entry.hrpOrigTrans  = origTrans
            -- Register for cross-injection restoration
            _HBGRegister(hrp, origSize, origTrans)
            local baseSize     = math.max(origSize.X, origSize.Y, origSize.Z)
            local expandedSize = baseSize * State.Hitbox.HRPMultiplier
            pcall(function()
                hrp.Size         = Vector3.new(expandedSize, expandedSize, expandedSize)
                hrp.CanCollide   = false
                hrp.Transparency = State.Hitbox.HRPTransparency
            end)
            count = count + 1
        end
    end

    if count == 0 then return end

    if State.Hitbox.Highlight then
        local hl = Instance.new("Highlight")
        hl.FillColor           = State.Hitbox.Color
        hl.OutlineColor        = State.Hitbox.Color
        hl.FillTransparency    = 0.45
        hl.OutlineTransparency = 0
        hl.Parent              = char
        entry.hl               = hl
    end

    HitboxData[player] = entry
end

local function RestoreHitboxForPlayer(player)
    local entry = HitboxData[player]
    if not entry then return end
    for part, origSize in pairs(entry.parts) do
        pcall(function()
            if part and part.Parent then
                part.Size = origSize
                if entry.partOrigTrans and entry.partOrigTrans[part] ~= nil then
                    part.Transparency = entry.partOrigTrans[part]
                end
            end
        end)
    end
    if entry.hrpPart and entry.hrpOrigSize then
        pcall(function()
            if entry.hrpPart and entry.hrpPart.Parent then
                entry.hrpPart.Size = entry.hrpOrigSize
                if entry.hrpOrigTrans ~= nil then
                    entry.hrpPart.Transparency = entry.hrpOrigTrans
                end
            end
        end)
    end
    if entry.hl then pcall(function() entry.hl:Destroy() end) end
    HitboxData[player] = nil
end

local function ClearAllHitboxes()
    for player in pairs(HitboxData) do RestoreHitboxForPlayer(player) end
    HitboxData = {}
    -- Clear global restore table — all sizes are now restored
    _G._PolarisHitboxData = {}
end

local function SetupHitbox()
    Drop("HitboxClean")
    if not State.Hitbox.Enabled then ClearAllHitboxes(); return end

    for _, p in ipairs(Players:GetPlayers()) do ApplyHitboxToPlayer(p) end

    Conn("HitboxClean", RunService.Heartbeat:Connect(function()
        if not State.Hitbox.Enabled then return end
        local expand = State.Hitbox.Size

        for _, p in ipairs(Players:GetPlayers()) do
            if p ~= LocalPlayer and not HitboxData[p] then ApplyHitboxToPlayer(p) end
        end

        local needReapply = {}

        for player, entry in pairs(HitboxData) do
            local char = GetCharacter(player)
            if not char then
                RestoreHitboxForPlayer(player)
            else
                local anyGone = false
                for part in pairs(entry.parts) do
                    if not part or not part.Parent or not part:IsDescendantOf(char) then
                        anyGone = true; break
                    end
                end
                if not anyGone and entry.hrpPart then
                    if not entry.hrpPart.Parent or not entry.hrpPart:IsDescendantOf(char) then
                        anyGone = true
                    end
                end
                if anyGone then
                    RestoreHitboxForPlayer(player)
                    table.insert(needReapply, player)
                else
                    for part, origSize in pairs(entry.parts) do
                        pcall(function()
                            local want = origSize + Vector3.new(expand, expand, expand) * 2
                            if part.Size ~= want then part.Size = want end
                            if part.Transparency ~= State.Hitbox.Transparency then
                                part.Transparency = State.Hitbox.Transparency
                            end
                        end)
                    end
                    if State.Hitbox.HRPEnabled and entry.hrpPart and entry.hrpOrigSize then
                        pcall(function()
                            if entry.hrpPart and entry.hrpPart.Parent then
                                local baseSize    = math.max(entry.hrpOrigSize.X, entry.hrpOrigSize.Y, entry.hrpOrigSize.Z)
                                local expandedSize = baseSize * State.Hitbox.HRPMultiplier
                                local want = Vector3.new(expandedSize, expandedSize, expandedSize)
                                if entry.hrpPart.Size ~= want then entry.hrpPart.Size = want end
                                if entry.hrpPart.Transparency ~= State.Hitbox.HRPTransparency then
                                    entry.hrpPart.Transparency = State.Hitbox.HRPTransparency
                                end
                            end
                        end)
                    elseif not State.Hitbox.HRPEnabled and entry.hrpPart and entry.hrpOrigSize then
                        pcall(function()
                            if entry.hrpPart and entry.hrpPart.Parent then
                                entry.hrpPart.Size = entry.hrpOrigSize
                            end
                        end)
                        entry.hrpPart = nil; entry.hrpOrigSize = nil
                    end
                    if State.Hitbox.Highlight then
                        if not entry.hl or not entry.hl.Parent then
                            local hl = Instance.new("Highlight")
                            hl.FillColor=State.Hitbox.Color; hl.OutlineColor=State.Hitbox.Color
                            hl.FillTransparency=0.45; hl.OutlineTransparency=0; hl.Parent=char
                            entry.hl = hl
                        else
                            entry.hl.FillColor    = State.Hitbox.Color
                            entry.hl.OutlineColor = State.Hitbox.Color
                        end
                    else
                        if entry.hl then pcall(function() entry.hl:Destroy() end); entry.hl=nil end
                    end
                end
            end
        end

        for _, player in ipairs(needReapply) do
            ApplyHitboxToPlayer(player)
        end
    end))
end

local function SetupAntiFling()
    Drop("AntiFling"); if not State.AntiFling then return end
    Conn("AntiFling", RunService.Heartbeat:Connect(function()
        local r=GetRoot(LocalPlayer)
        if r and r.AssemblyLinearVelocity.Magnitude>100 then r.AssemblyLinearVelocity=Vector3.zero end
    end))
end

local function OnCharacterAdded()
    task.wait(0.5); TweenTPActive=false
    if SpinBAV then pcall(function() SpinBAV:Destroy() end); SpinBAV=nil end
    RefreshDefaults()
    if State.Movement.Fly       then SetupFly()       end
    if State.Movement.Spin      then SetupSpin()      end
    if State.Movement.WalkSpeed then ApplyWalkSpeed()  end
    if State.Movement.JumpPower then
        local h=GetHumanoid(LocalPlayer); if h then h.JumpPower=State.Movement.JumpPowerValue end
    end
    if State.Movement.GodMode   then SetupGodMode()   end
    if State.Movement.InfJump   then SetupInfJump()   end
    if State.Movement.Noclip    then SetupNoclip()     end
end

-- ============================================================
-- // MUSIC
-- ============================================================

local MusicSound=Instance.new("Sound"); MusicSound.Name="PolarisMusic"; MusicSound.Parent=SoundService

local function ApplyMusicSettings()
    MusicSound.Volume=State.Music.Volume
    pcall(function() MusicSound.PlaybackSpeed=State.Music.Pitch end)
    MusicSound.Looped=State.Music.Looped
end

local function PlayMusic()
    if State.Music.ID=="" then return end
    MusicSound.SoundId="rbxassetid://"..State.Music.ID; ApplyMusicSettings(); MusicSound:Play()
    State.Music.Playing=true
end

local function StopMusic()
    MusicSound:Stop(); State.Music.Playing=false
end

-- ============================================================
-- // CONFIG SYSTEM
-- ============================================================

local CFG_FOLDER="polaris_configs"; local CFG_EXT=".json"; local CFG_AUTOLOAD="polaris_autoload.txt"

local function C3S(c) return {c.R,c.G,c.B} end
local function SC3(t)
    if type(t)~="table" or not t[1] then return nil end; return Color3.new(t[1],t[2],t[3])
end

local function SerializeState()
    local hbParts={}; for k,v in pairs(State.Hitbox.Parts) do hbParts[k]=v end
    local cps={}; for _,p in ipairs(State.Music.CustomPresets) do table.insert(cps,{name=p.name,id=p.id}) end
    return {
        Aimbot={Enabled=State.Aimbot.Enabled,KeepLocked=State.Aimbot.KeepLocked,
            Smoothness=State.Aimbot.Smoothness,FOV=State.Aimbot.FOV,Color=C3S(State.Aimbot.Color),
            LockKey=State.Aimbot.LockKey,WallCheck=State.Aimbot.WallCheck,
            Prediction=State.Aimbot.Prediction,PredictionStrength=State.Aimbot.PredictionStrength,
            TeamCheck=State.Aimbot.TeamCheck,RainbowFOV=State.Aimbot.RainbowFOV,
            RainbowSpeed=State.Aimbot.RainbowSpeed,TargetPart=State.Aimbot.TargetPart},
        ESP={Enabled=State.ESP.Enabled,Box=State.ESP.Box,Skeleton=State.ESP.Skeleton,
            Names=State.ESP.Names,Distance=State.ESP.Distance,Highlight=State.ESP.Highlight,
            Tracer=State.ESP.Tracer,Color=C3S(State.ESP.Color),Rainbow=State.ESP.Rainbow,
            RainbowSpeed=State.ESP.RainbowSpeed,TeamCheck=State.ESP.TeamCheck,
            TeamMode=State.ESP.TeamMode,TeamColor=C3S(State.ESP.TeamColor),MaxDist=State.ESP.MaxDist},
        Movement={WalkSpeed=State.Movement.WalkSpeed,WalkSpeedValue=State.Movement.WalkSpeedValue,
            JumpPower=State.Movement.JumpPower,JumpPowerValue=State.Movement.JumpPowerValue,
            InfJump=State.Movement.InfJump,Fly=State.Movement.Fly,FlySpeed=State.Movement.FlySpeed,
            Spin=State.Movement.Spin,SpinSpeed=State.Movement.SpinSpeed,
            TPWalk=State.Movement.TPWalk,TPWalkTween=State.Movement.TPWalkTween,
            TPWalkSpeed=State.Movement.TPWalkSpeed,ClickTP=State.Movement.ClickTP,
            ClickTweenTP=State.Movement.ClickTweenTP,ClickTweenTPSpeed=State.Movement.ClickTweenTPSpeed,
            Noclip=State.Movement.Noclip,GodMode=State.Movement.GodMode,
            Orbit=State.Movement.Orbit,OrbitSpeed=State.Movement.OrbitSpeed,
            OrbitRadius=State.Movement.OrbitRadius,OrbitMode=State.Movement.OrbitMode,
            OrbitCooldown=State.Movement.OrbitCooldown},
        Triggerbot={Enabled=State.Triggerbot.Enabled,Spam=State.Triggerbot.Spam,
            WallCheck=State.Triggerbot.WallCheck,TeamCheck=State.Triggerbot.TeamCheck,
            Radius=State.Triggerbot.Radius,Delay=State.Triggerbot.Delay},
        Hitbox={Enabled=State.Hitbox.Enabled,Size=State.Hitbox.Size,Color=C3S(State.Hitbox.Color),
            Highlight=State.Hitbox.Highlight,TeamCheck=State.Hitbox.TeamCheck,Parts=hbParts,
            Transparency=State.Hitbox.Transparency,
            HRPEnabled=State.Hitbox.HRPEnabled,HRPMultiplier=State.Hitbox.HRPMultiplier,
            HRPTransparency=State.Hitbox.HRPTransparency},
        Music={ID=State.Music.ID,Volume=State.Music.Volume,Pitch=State.Music.Pitch,
            Looped=State.Music.Looped,CustomPresets=cps},
        Fullbright=State.Fullbright,NoFog=State.NoFog,NoShadows=State.NoShadows,
        FPSBoost=State.FPSBoost,AntiFling=State.AntiFling,CameraFOV=State.CameraFOV,
    }
end

local function ApplyDeserializedState(d)
    if not d then return end
    if d.Aimbot then
        local a=d.Aimbot
        if a.Enabled~=nil            then State.Aimbot.Enabled=a.Enabled                                end
        if a.KeepLocked~=nil         then State.Aimbot.KeepLocked=a.KeepLocked                         end
        if a.Smoothness~=nil         then State.Aimbot.Smoothness=a.Smoothness                         end
        if a.FOV~=nil                then State.Aimbot.FOV=a.FOV                                       end
        if a.Color~=nil              then State.Aimbot.Color=SC3(a.Color) or State.Aimbot.Color        end
        if a.LockKey~=nil            then State.Aimbot.LockKey=a.LockKey                               end
        if a.WallCheck~=nil          then State.Aimbot.WallCheck=a.WallCheck                           end
        if a.Prediction~=nil         then State.Aimbot.Prediction=a.Prediction                         end
        if a.PredictionStrength~=nil then State.Aimbot.PredictionStrength=a.PredictionStrength         end
        if a.TeamCheck~=nil          then State.Aimbot.TeamCheck=a.TeamCheck                           end
        if a.RainbowFOV~=nil         then State.Aimbot.RainbowFOV=a.RainbowFOV                         end
        if a.RainbowSpeed~=nil       then State.Aimbot.RainbowSpeed=a.RainbowSpeed                     end
        if a.TargetPart~=nil         then State.Aimbot.TargetPart=a.TargetPart                         end
        SetupAimbot()
    end
    if d.ESP then
        local e=d.ESP
        if e.Enabled~=nil      then State.ESP.Enabled=e.Enabled                                end
        if e.Box~=nil          then State.ESP.Box=e.Box                                        end
        if e.Skeleton~=nil     then State.ESP.Skeleton=e.Skeleton                              end
        if e.Names~=nil        then State.ESP.Names=e.Names                                    end
        if e.Distance~=nil     then State.ESP.Distance=e.Distance                              end
        if e.Highlight~=nil    then State.ESP.Highlight=e.Highlight                            end
        if e.Tracer~=nil       then State.ESP.Tracer=e.Tracer                                  end
        if e.Color~=nil        then State.ESP.Color=SC3(e.Color) or State.ESP.Color            end
        if e.Rainbow~=nil      then State.ESP.Rainbow=e.Rainbow                                end
        if e.RainbowSpeed~=nil then State.ESP.RainbowSpeed=e.RainbowSpeed                      end
        if e.TeamCheck~=nil    then State.ESP.TeamCheck=e.TeamCheck                            end
        if e.TeamMode~=nil     then State.ESP.TeamMode=e.TeamMode                              end
        if e.TeamColor~=nil    then State.ESP.TeamColor=SC3(e.TeamColor) or State.ESP.TeamColor end
        if e.MaxDist~=nil      then State.ESP.MaxDist=e.MaxDist                                end
        SetupESP()
    end
    if d.Movement then
        local m=d.Movement
        if m.WalkSpeed~=nil         then State.Movement.WalkSpeed=m.WalkSpeed                         end
        if m.WalkSpeedValue~=nil    then State.Movement.WalkSpeedValue=m.WalkSpeedValue               end
        if m.JumpPower~=nil         then State.Movement.JumpPower=m.JumpPower                         end
        if m.JumpPowerValue~=nil    then State.Movement.JumpPowerValue=m.JumpPowerValue               end
        if m.InfJump~=nil           then State.Movement.InfJump=m.InfJump; SetupInfJump()            end
        if m.FlySpeed~=nil          then State.Movement.FlySpeed=m.FlySpeed                           end
        if m.Fly~=nil               then State.Movement.Fly=m.Fly; SetupFly()                        end
        if m.SpinSpeed~=nil         then State.Movement.SpinSpeed=m.SpinSpeed                         end
        if m.Spin~=nil              then State.Movement.Spin=m.Spin; SetupSpin()                      end
        if m.TPWalkSpeed~=nil       then State.Movement.TPWalkSpeed=m.TPWalkSpeed                     end
        if m.TPWalkTween~=nil       then State.Movement.TPWalkTween=m.TPWalkTween                     end
        if m.TPWalk~=nil            then State.Movement.TPWalk=m.TPWalk; SetupTPWalk()                end
        if m.ClickTweenTPSpeed~=nil then State.Movement.ClickTweenTPSpeed=m.ClickTweenTPSpeed         end
        if m.ClickTP~=nil           then State.Movement.ClickTP=m.ClickTP                             end
        if m.ClickTweenTP~=nil      then State.Movement.ClickTweenTP=m.ClickTweenTP                   end
        if m.Noclip~=nil            then State.Movement.Noclip=m.Noclip; SetupNoclip()               end
        if m.GodMode~=nil           then State.Movement.GodMode=m.GodMode; SetupGodMode()            end
        if m.OrbitSpeed~=nil        then State.Movement.OrbitSpeed=m.OrbitSpeed                       end
        if m.OrbitRadius~=nil       then State.Movement.OrbitRadius=m.OrbitRadius                     end
        if m.OrbitMode~=nil         then State.Movement.OrbitMode=m.OrbitMode                         end
        if m.OrbitCooldown~=nil     then State.Movement.OrbitCooldown=m.OrbitCooldown                 end
        if m.Orbit~=nil             then State.Movement.Orbit=m.Orbit; SetupOrbit()                  end
        ApplyWalkSpeed()
        local _h2=GetHumanoid(LocalPlayer)
        if _h2 and State.Movement.JumpPower then _h2.JumpPower=State.Movement.JumpPowerValue end
    end
    if d.Triggerbot then
        local t=d.Triggerbot
        if t.Enabled~=nil   then State.Triggerbot.Enabled=t.Enabled     end
        if t.Spam~=nil       then State.Triggerbot.Spam=t.Spam           end
        if t.WallCheck~=nil  then State.Triggerbot.WallCheck=t.WallCheck end
        if t.TeamCheck~=nil  then State.Triggerbot.TeamCheck=t.TeamCheck end
        if t.Radius~=nil     then State.Triggerbot.Radius=t.Radius       end
        if t.Delay~=nil      then State.Triggerbot.Delay=t.Delay         end
    end
    if d.Hitbox then
        local h=d.Hitbox
        if h.Enabled~=nil   then State.Hitbox.Enabled=h.Enabled                                 end
        if h.Size~=nil       then State.Hitbox.Size=h.Size                                       end
        if h.Color~=nil      then State.Hitbox.Color=SC3(h.Color) or State.Hitbox.Color          end
        if h.Highlight~=nil  then State.Hitbox.Highlight=h.Highlight                             end
        if h.TeamCheck~=nil  then State.Hitbox.TeamCheck=h.TeamCheck                             end
        if type(h.Parts)=="table" then
            for k,v in pairs(h.Parts) do if State.Hitbox.Parts[k]~=nil then State.Hitbox.Parts[k]=v end end
        end
        if h.HRPEnabled~=nil      then State.Hitbox.HRPEnabled=h.HRPEnabled         end
        if h.HRPMultiplier~=nil   then State.Hitbox.HRPMultiplier=h.HRPMultiplier   end
        if h.Transparency~=nil    then State.Hitbox.Transparency=h.Transparency     end
        if h.HRPTransparency~=nil then State.Hitbox.HRPTransparency=h.HRPTransparency end
        if State.Hitbox.Enabled then ClearAllHitboxes(); SetupHitbox() end
    end
    if d.Music then
        local mu=d.Music
        if mu.ID~=nil     then State.Music.ID=mu.ID                                             end
        if mu.Volume~=nil then State.Music.Volume=mu.Volume; MusicSound.Volume=mu.Volume        end
        if mu.Pitch~=nil  then State.Music.Pitch=mu.Pitch; pcall(function() MusicSound.PlaybackSpeed=mu.Pitch end) end
        if mu.Looped~=nil then State.Music.Looped=mu.Looped; MusicSound.Looped=mu.Looped        end
        if type(mu.CustomPresets)=="table" then
            State.Music.CustomPresets={}
            for _,p in ipairs(mu.CustomPresets) do
                if type(p.name)=="string" and type(p.id)=="string" then
                    table.insert(State.Music.CustomPresets,{name=p.name,id=p.id}) end
            end
            if RefreshCustomPresets then pcall(RefreshCustomPresets) end
        end
    end
    if d.Fullbright~=nil then State.Fullbright=d.Fullbright; SetupFullbright() end
    if d.NoFog~=nil      then State.NoFog=d.NoFog;           SetupNoFog()      end
    if d.NoShadows~=nil  then State.NoShadows=d.NoShadows;   SetupNoShadows()  end
    if d.FPSBoost~=nil   then State.FPSBoost=d.FPSBoost;     SetupFPSBoost()   end
    if d.AntiFling~=nil  then State.AntiFling=d.AntiFling;   SetupAntiFling()  end
    if d.CameraFOV~=nil  then State.CameraFOV=d.CameraFOV;   GetCamera().FieldOfView=d.CameraFOV end
    task.defer(SyncGUI)
end

local function CFGEnsureFolder()
    pcall(function() if isfolder and not isfolder(CFG_FOLDER) then if makefolder then makefolder(CFG_FOLDER) end end end)
end
local function CFGList()
    local names={}
    pcall(function()
        if not (isfolder and listfiles) then return end
        if not isfolder(CFG_FOLDER) then return end
        for _,f in ipairs(listfiles(CFG_FOLDER)) do
            if not f:match("%.json$") then continue end
            local name=f:match("[/\\]?([^/\\]+)$")
            if name then name=name:gsub("%.json$",""); if name~="" then table.insert(names,name) end end
        end
    end); return names
end
local function CFGSave(name)
    if not writefile then return false,"writefile not available" end
    CFGEnsureFolder()
    local ok,data=pcall(SerializeState); if not ok then return false,"serialization failed" end
    local ok2,json=pcall(HttpService.JSONEncode,HttpService,data); if not ok2 then return false,"JSON encode failed" end
    local ok3=pcall(writefile,CFG_FOLDER.."/"..name..CFG_EXT,json); if not ok3 then return false,"write failed" end
    pcall(writefile,CFG_AUTOLOAD,name); return true
end
local function CFGLoad(name)
    if not readfile then return false,"readfile not available" end
    local ok,json=pcall(readfile,CFG_FOLDER.."/"..name..CFG_EXT)
    if not ok or not json or json=="" then return false,"file not found" end
    local ok2,data=pcall(HttpService.JSONDecode,HttpService,json)
    if not ok2 or not data then return false,"JSON decode failed" end
    pcall(ApplyDeserializedState,data); pcall(writefile,CFG_AUTOLOAD,name); return true
end
local function CFGDelete(name)
    pcall(function() if delfile then delfile(CFG_FOLDER.."/"..name..CFG_EXT) end end)
    pcall(function()
        if readfile then local ok,cur=pcall(readfile,CFG_AUTOLOAD)
            if ok and cur==name and writefile then writefile(CFG_AUTOLOAD,"") end end
    end)
end

local _cfgStatusLabel=nil
local function CFGAutoLoad() end

