MiscTab:CreateButton({Name="Copy Location to Clipboard",Callback=function()
    local root=GetRoot(LocalPlayer); if root then
        local p=root.Position; local txt=string.format("%.2f, %.2f, %.2f",p.X,p.Y,p.Z)
        CopyToClipboard(txt); PolarisNotify("Copied",txt,2) end end})
MiscTab:CreateSection("Kill Script")
MiscTab:CreateButton({Name="⚠  Kill Script",Callback=function()
    for name in pairs(Connections) do
        pcall(function() Connections[name]:Disconnect() end)
        Connections[name] = nil
    end
    pcall(ClearAllHitboxes)
    pcall(ClearAllESP)
    if _G._PolarisDrawings then
        for _, d in ipairs(_G._PolarisDrawings) do pcall(function() d:Remove() end) end
        _G._PolarisDrawings = nil
    end
    _G._PolarisHitboxData = nil
    pcall(function()
        local h = GetHumanoid(LocalPlayer)
        if h then
            h.WalkSpeed    = Defaults.WalkSpeed
            h.JumpPower    = Defaults.JumpPower
            h.PlatformStand = false
            pcall(function() h.BreakJointsOnDeath = true end)
            pcall(function() h.MaxHealth = 100; h.Health = 100 end)
        end
    end)
    pcall(function()
        local root = GetRoot(LocalPlayer)
        if root then
            local bv = root:FindFirstChild("FlyBV"); if bv then bv:Destroy() end
            local bg = root:FindFirstChild("FlyBG"); if bg then bg:Destroy() end
        end
    end)
    if SpinBAV then pcall(function() SpinBAV:Destroy() end); SpinBAV = nil end
    for part in pairs(NoclipParts) do
        pcall(function() if part and part.Parent then part.CanCollide = true end end)
    end
    NoclipParts = {}
    pcall(function()
        Lighting.Ambient        = LDefault.Ambient
        Lighting.OutdoorAmbient = LDefault.OutdoorAmbient
        Lighting.Brightness     = LDefault.Brightness
        Lighting.GlobalShadows  = LDefault.GlobalShadows
        Lighting.FogEnd         = LDefault.FogEnd
        Lighting.FogStart       = LDefault.FogStart
    end)
    pcall(function()
        local a = Lighting:FindFirstChildOfClass("Atmosphere")
        if a and next(AtmoDefault) then
            if AtmoDefault.Density  ~= nil then a.Density  = AtmoDefault.Density  end
            if AtmoDefault.Haze     ~= nil then a.Haze     = AtmoDefault.Haze     end
            if AtmoDefault.Glare    ~= nil then a.Glare    = AtmoDefault.Glare    end
            if AtmoDefault.FogBlend ~= nil then a.FogBlend = AtmoDefault.FogBlend end
        end
    end)
    pcall(function()
        for fx, was in pairs(PostFXSaved) do
            pcall(function() if fx and fx.Parent then fx.Enabled = was end end)
        end
        for v, was in pairs(FPSParticleCache) do
            pcall(function()
                if not v then return end
                if typeof(was) == "Instance" then
                    if v and not v.Parent then v.Parent = was end
                elseif v.Parent then
                    v.Enabled = was
                end
            end)
        end
        FPSParticleCache = {}
    end)
    pcall(function() settings().Rendering.QualityLevel = Enum.QualityLevel.Automatic end)
    pcall(function()
        local ugs = game:GetService("UserGameSettings")
        ugs.SavedQualityLevel = Enum.SavedQualitySetting.Automatic
    end)
    pcall(function() GetCamera().FieldOfView = 70 end)
    pcall(function() MusicSound:Stop(); MusicSound:Destroy() end)
    pcall(function() ScreenGui:Destroy() end)
    pcall(function() WatermarkGui:Destroy() end)
    GUISetters = {}
    LockedTarget = nil
    OrbitTarget  = nil
    TweenTPActive = false
    print("[polaris.gov] script killed.")
end})
