AimbotTab:CreateSection("Target Bone")
AimbotTab:CreateLabel("Select which body part the aimbot aims at:")
do
    local partOpts={{"Head","Head"},{"Torso","Torso"},{"HumanoidRootPart","HumanoidRootPart"},
        {"Right Arm","Right Arm"},{"Left Arm","Left Arm"},{"Right Leg","Right Leg"},{"Left Leg","Left Leg"}}
    local partBtns={}; local ms=Tabs["Aimbot"].Scroll
    local function SelPart(key)
        State.Aimbot.TargetPart=key
        for k,b in pairs(partBtns) do Tween(b,T_FAST,{BackgroundColor3=k==key and C.AccentDim or C.Element}) end
    end
    for _,opt in ipairs(partOpts) do
        local to=Tabs["Aimbot"].Order+1; Tabs["Aimbot"].Order=to
        local b=New("TextButton",{Size=UDim2.new(1,0,0,30),
            BackgroundColor3=opt[2]=="Head" and C.AccentDim or C.Element,
            BorderSizePixel=0,LayoutOrder=to,Text=opt[1],Font=Enum.Font.Gotham,TextSize=11,
            TextColor3=C.Text,Parent=ms},{New("UICorner",{CornerRadius=UDim.new(0,6)})})
        partBtns[opt[2]]=b
        b.MouseButton1Click:Connect(function() SelPart(opt[2]) end)
        b.MouseEnter:Connect(function() if State.Aimbot.TargetPart~=opt[2] then Tween(b,T_FAST,{BackgroundColor3=C.ElemHov}) end end)
        b.MouseLeave:Connect(function() if State.Aimbot.TargetPart~=opt[2] then Tween(b,T_FAST,{BackgroundColor3=C.Element}) end end)
    end
    -- Register target part buttons with SyncGUI
    RegisterSetter(
        function() return State.Aimbot.TargetPart end,
        function(v)
            for k,b in pairs(partBtns) do
                pcall(function() b.BackgroundColor3 = (k==v) and C.AccentDim or C.Element end)
            end
        end
    )
end
