MovementTab:CreateSection("Orbit")
MovementTab:CreateToggle({Name="Player Orbit",CurrentValue=false,
    StateGet=function() return State.Movement.Orbit end,
    Callback=function(v) State.Movement.Orbit=v; SetupOrbit() end})
MovementTab:CreateSlider({Name="Orbit Speed",Range={1,200},Increment=1,CurrentValue=20,
    StateGet=function() return State.Movement.OrbitSpeed end,
    Callback=function(v) State.Movement.OrbitSpeed=v end})
MovementTab:CreateSlider({Name="Orbit Radius",Range={2,30},Increment=1,CurrentValue=5,
    StateGet=function() return State.Movement.OrbitRadius end,
    Callback=function(v) State.Movement.OrbitRadius=v end})
do
    local modeBtns={}
    local function SelMode(mode)
        State.Movement.OrbitMode=mode
        for m,b in pairs(modeBtns) do Tween(b,T_FAST,{BackgroundColor3=m==mode and C.AccentDim or C.Element}) end
        if State.Movement.Orbit then SetupOrbit() end
    end
    local ms=Tabs["Movement"].Scroll
    local function MkBtn(lbl,modeKey,lo)
        local b=New("TextButton",{Size=UDim2.new(1,0,0,30),BackgroundColor3=modeKey=="click" and C.AccentDim or C.Element,
            BorderSizePixel=0,LayoutOrder=lo,Text=lbl,Font=Enum.Font.Gotham,TextSize=11,
            TextColor3=C.Text,Parent=ms},{New("UICorner",{CornerRadius=UDim.new(0,6)})})
        modeBtns[modeKey]=b; b.MouseButton1Click:Connect(function() SelMode(modeKey) end)
        b.MouseEnter:Connect(function() if State.Movement.OrbitMode~=modeKey then Tween(b,T_FAST,{BackgroundColor3=C.ElemHov}) end end)
        b.MouseLeave:Connect(function() if State.Movement.OrbitMode~=modeKey then Tween(b,T_FAST,{BackgroundColor3=C.Element}) end end)
    end
    local to=Tabs["Movement"].Order; MkBtn("Mode: Click to Select","click",to+1); MkBtn("Mode: Nearest Player","nearest",to+2); MkBtn("Mode: Auto Random","auto",to+3)
    Tabs["Movement"].Order=to+3
    RegisterSetter(
        function() return State.Movement.OrbitMode end,
        function(v)
            for m,b in pairs(modeBtns) do
                pcall(function() b.BackgroundColor3 = (m==v) and C.AccentDim or C.Element end)
            end
        end
    )
    MovementTab:CreateSlider({Name="Auto Switch Cooldown",Range={1,100},Increment=1,CurrentValue=10,
        StateGet=function() return math.floor(State.Movement.OrbitCooldown*10+0.5) end,
        Callback=function(v) State.Movement.OrbitCooldown=v/10 end})
end

-- ── MUSIC ─────────────────────────────────────────────────────

MusicTab:CreateSection("Built-in Presets")
do
    local bl={{name="Hava Nagila",id="1840529306"},{name="Clair de Lune",id="89577183427975"},{name="Moonlight Sonata",id="1848050065"}}
    for _,preset in ipairs(bl) do
        MusicTab:CreateButton({Name=preset.name,Callback=function()
            State.Music.ID=preset.id; MusicSound.SoundId="rbxassetid://"..preset.id
            ApplyMusicSettings(); MusicSound:Play(); State.Music.Playing=true
            PolarisNotify("Music","Playing: "..preset.name,3) end})
    end
end
MusicTab:CreateSection("Custom Presets")
MusicTab:CreateLabel("Add your own presets. They save with your config.")
local customPresetScroll=Tabs["Music"].Scroll; local customPresetLO={}
RefreshCustomPresets=function()
    for _,inst in ipairs(customPresetLO) do pcall(function() if inst and inst.Parent then inst:Destroy() end end) end
    customPresetLO={}
    for _,preset in ipairs(State.Music.CustomPresets) do
        local to=Tabs["Music"].Order+1; Tabs["Music"].Order=to
        local row=New("Frame",{Size=UDim2.new(1,0,0,36),BackgroundColor3=C.Element,BorderSizePixel=0,LayoutOrder=to,Parent=customPresetScroll},
            {New("UICorner",{CornerRadius=UDim.new(0,7)})})
        table.insert(customPresetLO,row)
        New("TextLabel",{Size=UDim2.new(1,-80,1,0),Position=UDim2.new(0,10,0,0),BackgroundTransparency=1,
            Text=preset.name,Font=Enum.Font.Gotham,TextSize=11,TextColor3=C.Text,
            TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=row})
        local playB=New("TextButton",{Size=UDim2.fromOffset(36,22),Position=UDim2.new(1,-76,0.5,-11),
            BackgroundColor3=C.AccentDim,BorderSizePixel=0,Text="Play",Font=Enum.Font.GothamBold,
            TextSize=9,TextColor3=C.White,ZIndex=4,Parent=row},{New("UICorner",{CornerRadius=UDim.new(0,5)})})
        local pid=preset.id; local pname=preset.name
        playB.MouseButton1Click:Connect(function()
            State.Music.ID=pid; MusicSound.SoundId="rbxassetid://"..pid
            ApplyMusicSettings(); MusicSound:Play(); State.Music.Playing=true; PolarisNotify("Music","Playing: "..pname,3) end)
        playB.MouseEnter:Connect(function() Tween(playB,T_FAST,{BackgroundColor3=C.Accent}) end)
        playB.MouseLeave:Connect(function() Tween(playB,T_FAST,{BackgroundColor3=C.AccentDim}) end)
        local delB=New("TextButton",{Size=UDim2.fromOffset(36,22),Position=UDim2.new(1,-36,0.5,-11),
            BackgroundColor3=C.Red,BorderSizePixel=0,Text="Del",Font=Enum.Font.GothamBold,
            TextSize=9,TextColor3=C.White,ZIndex=4,Parent=row},{New("UICorner",{CornerRadius=UDim.new(0,5)})})
        delB.MouseButton1Click:Connect(function()
            for i,p in ipairs(State.Music.CustomPresets) do
                if p.name==pname and p.id==pid then table.remove(State.Music.CustomPresets,i); break end
            end; RefreshCustomPresets() end)
        delB.MouseEnter:Connect(function() Tween(delB,T_FAST,{BackgroundColor3=Color3.fromRGB(255,80,80)}) end)
        delB.MouseLeave:Connect(function() Tween(delB,T_FAST,{BackgroundColor3=C.Red}) end)
    end
end
local _newPresetName=""; local _newPresetID=""
local addNameTO=Tabs["Music"].Order+1; Tabs["Music"].Order=addNameTO
local addNcon=New("Frame",{Size=UDim2.new(1,0,0,56),BackgroundColor3=C.Element,BorderSizePixel=0,LayoutOrder=addNameTO,Parent=customPresetScroll},
    {New("UICorner",{CornerRadius=UDim.new(0,7)})})
New("TextLabel",{Size=UDim2.new(1,-24,0,22),Position=UDim2.new(0,12,0,0),BackgroundTransparency=1,
    Text="Preset Name",Font=Enum.Font.Gotham,TextSize=12,TextColor3=C.Text,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=addNcon})
local addNameBox=New("TextBox",{Size=UDim2.new(1,-24,0,26),Position=UDim2.new(0,12,0,24),BackgroundColor3=C.SliderBG,
    BorderSizePixel=0,Text="",PlaceholderText="e.g. My Song",Font=Enum.Font.Gotham,TextSize=12,
    TextColor3=C.Text,PlaceholderColor3=C.TextMuted,ClearTextOnFocus=false,ZIndex=4,Parent=addNcon},
    {New("UICorner",{CornerRadius=UDim.new(0,5)}),New("UIPadding",{PaddingLeft=UDim.new(0,6)})})
addNameBox:GetPropertyChangedSignal("Text"):Connect(function() _newPresetName=addNameBox.Text end)
local addIDto=Tabs["Music"].Order+1; Tabs["Music"].Order=addIDto
local addIDcon=New("Frame",{Size=UDim2.new(1,0,0,56),BackgroundColor3=C.Element,BorderSizePixel=0,LayoutOrder=addIDto,Parent=customPresetScroll},
    {New("UICorner",{CornerRadius=UDim.new(0,7)})})
New("TextLabel",{Size=UDim2.new(1,-24,0,22),Position=UDim2.new(0,12,0,0),BackgroundTransparency=1,
    Text="Asset ID",Font=Enum.Font.Gotham,TextSize=12,TextColor3=C.Text,TextXAlignment=Enum.TextXAlignment.Left,ZIndex=3,Parent=addIDcon})
local addIDBox=New("TextBox",{Size=UDim2.new(1,-24,0,26),Position=UDim2.new(0,12,0,24),BackgroundColor3=C.SliderBG,
    BorderSizePixel=0,Text="",PlaceholderText="numeric ID",Font=Enum.Font.Gotham,TextSize=12,
    TextColor3=C.Text,PlaceholderColor3=C.TextMuted,ClearTextOnFocus=false,ZIndex=4,Parent=addIDcon},
    {New("UICorner",{CornerRadius=UDim.new(0,5)}),New("UIPadding",{PaddingLeft=UDim.new(0,6)})})
addIDBox:GetPropertyChangedSignal("Text"):Connect(function() _newPresetID=addIDBox.Text end)
local addBTO=Tabs["Music"].Order+1; Tabs["Music"].Order=addBTO
local addBtn=New("TextButton",{Size=UDim2.new(1,0,0,34),BackgroundColor3=C.Element,BorderSizePixel=0,LayoutOrder=addBTO,Text="",Parent=customPresetScroll},
    {New("UICorner",{CornerRadius=UDim.new(0,7)})})
New("TextLabel",{Size=UDim2.fromScale(1,1),BackgroundTransparency=1,Text="+ Add Preset",Font=Enum.Font.GothamBold,TextSize=12,TextColor3=C.On,ZIndex=3,Parent=addBtn})
addBtn.MouseButton1Click:Connect(function()
    local nm=_newPresetName:match("^%s*(.-)%s*$"); local id=_newPresetID:match("(%d+)")
    if nm=="" or not id then PolarisNotify("Music","Enter a name and valid asset ID.",2); return end
    table.insert(State.Music.CustomPresets,{name=nm,id=id})
    addNameBox.Text=""; _newPresetName=""; addIDBox.Text=""; _newPresetID=""
    RefreshCustomPresets(); PolarisNotify("Music","Preset added: "..nm,2)
end)
addBtn.MouseEnter:Connect(function() Tween(addBtn,T_FAST,{BackgroundColor3=C.ElemHov}) end)
addBtn.MouseLeave:Connect(function() Tween(addBtn,T_FAST,{BackgroundColor3=C.Element}) end)
RefreshCustomPresets()
MusicTab:CreateSection("Player")
MusicTab:CreateTextInput({Name="Asset ID",Placeholder="Enter numeric ID",DefaultText="",
    Callback=function(v) local id=v:match("(%d+)"); if id then State.Music.ID=id end end})
MusicTab:CreateSlider({Name="Volume",Range={0,100},Increment=1,Suffix="%",CurrentValue=50,
    Callback=function(v) State.Music.Volume=v/100; MusicSound.Volume=State.Music.Volume end})
MusicTab:CreateSlider({Name="Pitch",Range={25,400},Increment=5,Suffix="%",CurrentValue=100,
    Callback=function(v) State.Music.Pitch=v/100; pcall(function() MusicSound.PlaybackSpeed=State.Music.Pitch end) end})
MusicTab:CreateToggle({Name="Loop",CurrentValue=false,Callback=function(v) State.Music.Looped=v; MusicSound.Looped=v end})
MusicTab:CreateButton({Name="Play",Callback=function()
    PlayMusic(); PolarisNotify("Music","Playing ID: "..(State.Music.ID~="" and State.Music.ID or "none"),3) end})
MusicTab:CreateButton({Name="Stop",Callback=function() StopMusic() end})
MusicTab:CreateLabel("Enter asset ID (numbers only). Press Play.")

