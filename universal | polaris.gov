local function New(class,props,children)
    local ok,inst=pcall(Instance.new,class); if not ok then return nil end
    if props then for k,v in pairs(props) do pcall(function() inst[k]=v end) end end
    if children then for _,c in ipairs(children) do if c then c.Parent=inst end end end
    return inst
end
local function Tween(inst,info,props)
    if inst and inst.Parent then TweenService:Create(inst,info,props):Play() end
end
local T_FAST=TweenInfo.new(0.12,Enum.EasingStyle.Quad,Enum.EasingDirection.Out)
local T_MED =TweenInfo.new(0.22,Enum.EasingStyle.Quad,Enum.EasingDirection.Out)

