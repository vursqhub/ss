local LocalPlayer = Players.LocalPlayer
local Mouse       = LocalPlayer:GetMouse()

-- ============================================================
-- // HELPERS
-- ============================================================

local function GetCamera()  return workspace.CurrentCamera end
local function GetCharacter(p) return p and p.Character end
local function GetRoot(p)
    local c = GetCharacter(p)
    return c and c:FindFirstChild("HumanoidRootPart")
end
local function GetHumanoid(p)
    local c = GetCharacter(p)
    return c and c:FindFirstChildOfClass("Humanoid")
end
local function IsAlive(p)
    local h = GetHumanoid(p)
    return h ~= nil and h.Health > 0
end
local function IsTeammate(player)
    if not LocalPlayer.Team then return false end
    return player.Team ~= nil and player.Team == LocalPlayer.Team
end
local function W2S(pos)
    local v, on = GetCamera():WorldToViewportPoint(pos)
    return Vector2.new(v.X, v.Y), on
end
local function CopyToClipboard(text)
    if setclipboard then
        setclipboard(text)
    elseif Clipboard and Clipboard.set then
        Clipboard.set(text)
    end
end

